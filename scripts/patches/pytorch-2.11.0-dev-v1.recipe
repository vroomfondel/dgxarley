#
# Custom pytorch dev base recipe: xomoxcc/dgx-spark-pytorch-dev:2.11.0-v1-cu132
#
# Purpose: build the CUDA 13.2 + PyTorch 2.11.0 base image that scitrera's
# sglang-0.5.10.recipe references as BASE_IMAGE, but which scitrera has NOT
# yet published to Docker Hub (the recipe is in their repo since 2026-04-08
# but depends on an unpublished NCCL fork and wasn't built+pushed by the
# maintainer). See reference_sm121_build_base_regression memory for context.
#
# This is a verbatim copy of scitrera's pytorch-2.11.0-dev-v1.recipe EXCEPT:
# 1. NCCL: switched from scitrera's draft NCCL fork to upstream NVIDIA/nccl
#    v2.30.4-1 (newest full release). scitrera's draft pinned the unpublished
#    zyang-dev/nccl#dgxspark-3node-ring fork, whose sole patch is a DEFAULT-OFF
#    "subnet-aware routing" feature (NCCL_IB_SUBNET_AWARE_ROUTING) for multi-
#    subnet direct-connect RoCE rings — a verified no-op on our single-/24
#    (10.10.10.0/24) switched (CRS812) fabric. See pytorch-2.12.0-dev-v1.recipe
#    for the full analysis. Upstream loses us nothing and tracks current NCCL.
# 2. IMAGE_TAG: "scitrera/dgx-spark-pytorch-dev:..." -> "xomoxcc/..."
#    Uses our namespace to avoid colliding with any future upstream build.
#
# Upstream reference (do not modify their file; this is our local copy):
#   https://github.com/scitrera/cuda-containers/blob/main/container-recipes/pytorch-2.11.0-dev-v1.recipe
#
DOCKERFILE=Dockerfile.base
TARGET=pytorch_builder

CUDA_VERSION=13.2.0
CUDA_SHORT=132

NCCL_VERSION=2.30.4-1
NCCL_REF=v2.30.4-1
NCCL_REPO=https://github.com/NVIDIA/nccl.git

BUILD_JOBS=8

#TORCH_CUDA_ARCH_LIST=12.1a
#NVCC_GENCODE=-gencode=arch=compute_121,code=sm_121
TORCH_CUDA_ARCH_LIST="12.0;12.1"
NVCC_GENCODE="-gencode=arch=compute_120,code=sm_120 -gencode=arch=compute_121,code=sm_121"

TORCH_VERSION=2.11.0
TORCH_AUDIO_VERSION=2.11.0
TORCH_VISION_VERSION=0.26.0

IMAGE_TAG=xomoxcc/dgx-spark-pytorch-dev:2.11.0-v1-cu132
