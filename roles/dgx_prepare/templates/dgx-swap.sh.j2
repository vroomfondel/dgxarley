#!/usr/bin/env bash
# dgx-swap — per-node disk-backed swapfile toggle for DGX sparks (KEP-2400 node swap).
#
# Generated by Ansible (dgx_prepare role) for {{ inventory_hostname }}.
# Distributed to /root/dgx-swap.sh on EVERY spark, regardless of the fleet-wide
# k3s_node_swap_enabled flag — so you can flip swap on/off on a SINGLE node by hand
# (e.g. give one spark headroom for a memory-hungry run without touching the others).
#
# This mirrors the logic of roles/dgx_prepare/tasks/swap.yml. The Ansible task stays
# the source of truth for fleet-wide state; the next role run reconciles a node back
# to k3s_node_swap_enabled. This script is for individual / out-of-band control.
#
# NOTE: manages the swap *device* only — it does NOT touch k3s/kubelet config
# (failSwapOn / swapBehavior), which come from the k3sserver role. Enabling swap here
# on a node whose kubelet was started with failSwapOn=true won't be used by the kubelet
# until it is restarted with the matching config.
#
# Usage (run as root on the spark):
#   ./dgx-swap status              # show current swap state
#   ./dgx-swap on                  # create + activate a {{ dgx_swap_size }} swapfile (transient)
#   ./dgx-swap on 64G              # ... with a specific size
#   ./dgx-swap on --persist        # ... and add an /etc/fstab entry (survives reboot)
#   ./dgx-swap on --force          # ... skip the DiskPressure free-space guard
#   ./dgx-swap off                 # deactivate + delete swapfile + drop fstab/sysctl drop-in

set -euo pipefail

# --- Baked-in defaults from the dgx_prepare role (override on the CLI) ---
SWAP_FILE="{{ dgx_swap_file }}"
SWAP_SIZE_DEFAULT="{{ dgx_swap_size }}"
SWAPPINESS="{{ dgx_swap_swappiness }}"
MIN_FREE_PCT="{{ dgx_swap_min_free_pct }}"
SYSCTL_DROPIN="/etc/sysctl.d/99-dgx-swap.conf"
FSTAB="/etc/fstab"
# OS-default swapfiles (e.g. DGX-OS /swap.img) that `off` should ALSO remove, so a
# disabled node is genuinely swap-free. Mirrors dgx_swap_foreign_files in swap.yml.
FOREIGN_FILES=({% for f in dgx_swap_foreign_files | default([]) %}{{ f | quote }} {% endfor %})

[ "$(id -u)" -eq 0 ] || { echo "ERROR: must run as root." >&2; exit 1; }

to_bytes() {  # human size (100G / 64g / 1024M) -> bytes; G/M/K are powers of 1024 (matches fallocate)
    numfmt --from=iec "${1^^}" 2>/dev/null || { echo "ERROR: bad size '$1'" >&2; exit 1; }
}

is_active() { swapon --noheadings --show=NAME 2>/dev/null | grep -qxF "$SWAP_FILE"; }

# fstab helpers use awk field-equality (no regex escaping of the path needed).
fstab_present() { awk -v f="$SWAP_FILE" '$1==f{found=1} END{exit !found}' "$FSTAB"; }
fstab_add()     { fstab_present || echo "$SWAP_FILE none swap sw 0 0" >> "$FSTAB"; }
fstab_remove()  { fstab_remove_path "$SWAP_FILE"; }
# Drop any fstab line whose mount source is the given path (field-equality, no regex).
fstab_remove_path() {
    local f="$1"
    awk -v f="$f" '$1==f{found=1} END{exit !found}' "$FSTAB" || return 0
    awk -v f="$f" '$1!=f' "$FSTAB" > "${FSTAB}.dgx-swap.tmp" \
        && mv "${FSTAB}.dgx-swap.tmp" "$FSTAB"
}

cmd_status() {
    echo "=== dgx-swap status ({{ inventory_hostname }}) ==="
    echo "swapfile  : $SWAP_FILE"
    if [ -e "$SWAP_FILE" ]; then
        echo "exists    : yes ($(numfmt --to=iec "$(stat -c%s "$SWAP_FILE")"))"
    else
        echo "exists    : no"
    fi
    echo "active    : $(is_active && echo yes || echo no)"
    echo "fstab     : $(fstab_present && echo present || echo absent)"
    echo "swappiness: $(cat /proc/sys/vm/swappiness)"
    echo ""
    swapon --show 2>/dev/null || true
    is_active || echo "(swapfile not active)"
}

cmd_on() {
    local size="$SWAP_SIZE_DEFAULT" persist=0 force=0 arg
    for arg in "$@"; do
        case "$arg" in
            --persist) persist=1 ;;
            --force)   force=1 ;;
            --*)       echo "ERROR: unknown flag '$arg'" >&2; exit 1 ;;
            *)         size="$arg" ;;
        esac
    done

    local want_bytes cur_bytes=0
    want_bytes="$(to_bytes "$size")"
    [ -e "$SWAP_FILE" ] && cur_bytes="$(stat -c%s "$SWAP_FILE")"

    # DiskPressure guard (mirrors swap.yml): net-new bytes must leave >= MIN_FREE_PCT% free
    # on the swapfile's filesystem, or the kubelet nodefs eviction threshold could trip.
    if [ "$force" -eq 0 ]; then
        local dir avail total min_free net_new avail_after
        dir="$(dirname "$SWAP_FILE")"
        avail="$(df -B1 --output=avail "$dir" | tail -1 | tr -d ' ')"
        total="$(df -B1 --output=size  "$dir" | tail -1 | tr -d ' ')"
        min_free=$(( total * MIN_FREE_PCT / 100 ))
        net_new=$(( want_bytes - cur_bytes )); [ "$net_new" -lt 0 ] && net_new=0
        avail_after=$(( avail - net_new ))
        if [ "$avail_after" -lt "$min_free" ]; then
            echo "ERROR: a ${size} swapfile would leave only $(numfmt --to=iec "$avail_after") free on ${dir}" >&2
            echo "       (< ${MIN_FREE_PCT}% = $(numfmt --to=iec "$min_free")), risking a DiskPressure taint" >&2
            echo "       + pod eviction. Shrink the size or pass --force." >&2
            exit 1
        fi
    fi

    # Resize: if a swapfile exists at a different size, deactivate + remove to re-allocate.
    if [ -e "$SWAP_FILE" ] && [ "$cur_bytes" -ne "$want_bytes" ]; then
        echo "Resizing swapfile ($(numfmt --to=iec "$cur_bytes") -> ${size})..."
        is_active && swapoff "$SWAP_FILE"
        rm -f "$SWAP_FILE"
    fi

    if [ ! -e "$SWAP_FILE" ]; then
        echo "Allocating ${size} at ${SWAP_FILE}..."
        fallocate -l "$size" "$SWAP_FILE"
        chown root:root "$SWAP_FILE"
        chmod 0600 "$SWAP_FILE"
        mkswap "$SWAP_FILE" >/dev/null
    fi

    if is_active; then
        echo "Swap already active."
    else
        swapon "$SWAP_FILE"
        echo "Swap activated."
    fi

    sysctl -qw "vm.swappiness=${SWAPPINESS}"
    printf 'vm.swappiness = %s\n' "$SWAPPINESS" > "$SYSCTL_DROPIN"

    if [ "$persist" -eq 1 ]; then
        fstab_add
        echo "Persisted in ${FSTAB} (survives reboot)."
    else
        fstab_remove
    fi

    echo ""
    cmd_status
}

cmd_off() {
    # Remove the role-managed swapfile AND any OS-default swapfiles (FOREIGN_FILES,
    # e.g. /swap.img) so the node ends up genuinely swap-free.
    local f
    for f in "$SWAP_FILE" "${FOREIGN_FILES[@]}"; do
        if swapon --noheadings --show=NAME 2>/dev/null | grep -qxF "$f"; then
            swapoff "$f"
            echo "Swap deactivated: $f"
        fi
        if [ -e "$f" ]; then
            rm -f "$f"
            echo "Removed $f."
        fi
        fstab_remove_path "$f"
    done
    rm -f "$SYSCTL_DROPIN"
    echo ""
    cmd_status
}

case "${1:-status}" in
    on)         shift; cmd_on "$@" ;;
    off)        cmd_off ;;
    status)     cmd_status ;;
    *)          echo "usage: ${0##*/} {on [size] [--persist] [--force] | off | status}" >&2; exit 1 ;;
esac
