#iptables -A HTSTUFFIN -s 192.168.101.0/24  -p tcp -m tcp --dport 20 -m conntrack --ctstate ESTABLISHED -j ACCEPT -m comment --comment "Allow ftp connections on port 20"

#iptables -A HTSTUFFIN -s 192.168.1.0/24 -d 192.168.1.0/24 -p tcp -m tcp --dport 21 -m conntrack --ctstate NEW,ESTABLISHED -j ACCEPT
#iptables -A HTSTUFFIN -s 192.168.1.0/24 -d 192.168.1.0/24 -p tcp -m tcp --dport 20 -m conntrack --ctstate ESTABLISHED -j ACCEPT
#iptables -A HTSTUFFIN -s 192.168.1.0/24 -d 192.168.1.0/24 -p tcp -m tcp --sport 1024: --dport 1024: -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
#iptables -A OUTPUT -s 192.168.1.0/24 -d 192.168.1.0/24 -p tcp -m tcp --sport 21 -m conntrack --ctstate ESTABLISHED -j ACCEPT
#iptables -A OUTPUT -s 192.168.1.0/24 -d 192.168.1.0/24 -p tcp -m tcp --sport 20 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
#iptables -A OUTPUT -s 192.168.1.0/24 -d 192.168.1.0/24 -p tcp -m tcp --sport 1024:65535 --dport 1024:65535 -m conntrack --ctstate ESTABLISHED -j ACCEPT


#iptables -A HTSTUFFIN -m state --state NEW,INVALID -m set \! --match-set geoblocklist src -m limit --limit 10/min -j LOG --log-prefix "IPTABLES_DROP_HTSTUFFIN_ALLOW " --log-level 4
#iptables -A HTSTUFFIN -m state --state NEW,INVALID -m set \! --match-set geoblocklist src -j DROP

#iptables -A HTSTUFFIN -m limit --limit 10/min -j LOG --log-prefix "IPTABLES_DROP_HTSTUFFIN " --log-level 4
#iptables -A HTSTUFFIN -m state --state NEW,INVALID -j DROP


#iptables -A OUTPUT -p tcp -j ACCEPT

iptables -F HTSTUFFOUT

iptables -D OUTPUT -j HTSTUFFOUT
iptables -I OUTPUT 1 -j HTSTUFFOUT

iptables -A HTSTUFFOUT -p icmp -j RETURN
iptables -A HTSTUFFOUT -p tcp -j RETURN
iptables -A HTSTUFFOUT -p udp -j RETURN
iptables -A HTSTUFFOUT -p igmp -j RETURN
{% if keepalived_vlans is defined %}
iptables -A HTSTUFFOUT -p 112 -j RETURN
{% endif %}
iptables -A HTSTUFFOUT -m limit --limit 10/min -j LOG --log-prefix "IPTABLES_REJECT_HTSTUFFOUT " --log-level 4
iptables -A HTSTUFFOUT -j DROP


# iptables -A FORWARD -j blocklists
# iptables -A FORWARD -m set --match-set geoblocklist src -j DROP


#https://gist.github.com/juliojsb/00e3bb086fd4e0472dbe
#iptables -A HTSTUFFIN   -m pkttype --pkt-type multicast -j ACCEPT
#iptables -A FORWARD -m pkttype --pkt-type multicast -j ACCEPT
#iptables -A OUTPUT  -m pkttype --pkt-type multicast -j ACCEPT

#iptables -A HTSTUFFIN   -s 224.0.0.0/4 -j ACCEPT
#iptables -A FORWARD -s 224.0.0.0/4 -d 224.0.0.0/4 -j ACCEPT
#iptables -A OUTPUT  -d 224.0.0.0/4 -j ACCEPT

{% set fwmark_rules = [] %}
{% for vlan_id, vlan_cfg in (ovs_vlan_extra | default({})).items() %}
{% for rule in vlan_cfg.fwmark_routing | default([]) %}
{% set _ = fwmark_rules.append(rule | combine({'iface': ovs_bridge_name ~ '.' ~ vlan_id})) %}
{% endfor %}
{% endfor %}
{% for rule in fwmark_routing | default([]) %}
{% set _ = fwmark_rules.append(rule) %}
{% endfor %}
{% if fwmark_rules | length > 0 %}

# --- mangle table: conntrack-based return-path routing ---
# PREROUTING: mark NEW inbound connections arriving on the routed VLAN interface
iptables -t mangle -N HTFWMARK_PRE 2>/dev/null || true
iptables -t mangle -F HTFWMARK_PRE
iptables -t mangle -D PREROUTING -j HTFWMARK_PRE 2>/dev/null || true
iptables -t mangle -I PREROUTING 1 -j HTFWMARK_PRE

{% for rule in fwmark_rules %}
iptables -t mangle -A HTFWMARK_PRE -i {{ rule.iface }} -s {{ rule.inbound_src }} -d {{ rule.inbound_dst }} -m conntrack --ctstate NEW -j CONNMARK --set-mark {{ rule.mark }}
{% endfor %}

# OUTPUT: restore connection marks → packet marks (reply packets get the fwmark)
iptables -t mangle -N HTFWMARK_OUT 2>/dev/null || true
iptables -t mangle -F HTFWMARK_OUT
iptables -t mangle -D OUTPUT -j HTFWMARK_OUT 2>/dev/null || true
iptables -t mangle -I OUTPUT 1 -j HTFWMARK_OUT

iptables -t mangle -A HTFWMARK_OUT -j CONNMARK --restore-mark

# ip rule: fwmark → routing table
{% for rule in fwmark_rules %}
ip rule del fwmark {{ rule.mark }} table {{ rule.table }} 2>/dev/null || true
ip rule add fwmark {{ rule.mark }} table {{ rule.table }}
{% endfor %}
{% endif %}

exit 0

