OPENAI_API_KEY={{ item.litellm_token }}
SEARXNG_URL={{ hermes_searxng_url | default('http://searxng.searxng.svc.cluster.local:' ~ searxng_port) }}
{% set email = item.email | default({}) %}
{% if email.get('enabled', hermes.email.enabled_default) %}
EMAIL_ADDRESS={{ email.address }}
EMAIL_PASSWORD={{ email.password }}
EMAIL_IMAP_HOST={{ email.imap_host }}
EMAIL_SMTP_HOST={{ email.smtp_host }}
EMAIL_IMAP_PORT={{ email.imap_port | default(993) }}
EMAIL_SMTP_PORT={{ email.smtp_port | default(587) }}
EMAIL_POLL_INTERVAL={{ email.poll_interval | default(15) }}
{% if email.home_address is defined %}
EMAIL_HOME_ADDRESS={{ email.home_address }}
{% endif %}
{% if email.allow_all_users is defined %}
EMAIL_ALLOW_ALL_USERS={{ 'true' if email.allow_all_users else 'false' }}
{% endif %}
{% if email.allowed_users is defined %}
EMAIL_ALLOWED_USERS={{ email.allowed_users | join(',') if email.allowed_users is iterable and email.allowed_users is not string else email.allowed_users }}
{% endif %}
{# dgxarley local-patch behavioural knobs (working_folder, done_folder,
   sent_folder, process_existing) are NOT env vars — they live in config.yaml
   under platforms.email.extra (see hermes_config.yaml.j2 and
   roles/k8s_infra/files/hermes_email_gateway_patched.py), mirroring upstream PRs
   #28697 / #28699 / #28702. #}
{% endif %}
{# Matrix gateway — read by `hermes gateway run` (platforms/matrix.py, mautrix
   SDK). Pure-env, no source patch. Both auth methods are allowed: an
   access_token takes precedence in matrix.py; user_id+password is the
   alternative (and the way to bootstrap a token on first login). E2EE
   (mautrix[encryption], present in the image) persists its crypto.db under
   HERMES_HOME=/opt/data (NFS), keyed by the stable MATRIX_DEVICE_ID. #}
{% set matrix = item.matrix | default({}) %}
{% if matrix.get('enabled', hermes.matrix.enabled_default) %}
MATRIX_HOMESERVER={{ matrix.homeserver }}
{% if matrix.access_token is defined %}
MATRIX_ACCESS_TOKEN={{ matrix.access_token }}
{% endif %}
{% if matrix.user_id is defined %}
MATRIX_USER_ID={{ matrix.user_id }}
{% endif %}
{% if matrix.password is defined %}
MATRIX_PASSWORD={{ matrix.password }}
{% endif %}
MATRIX_DEVICE_ID={{ matrix.device_id | default('hermes-' ~ item.username) }}
MATRIX_E2EE_MODE={{ matrix.e2ee_mode | default('required') }}
{% if matrix.allowed_users is defined %}
MATRIX_ALLOWED_USERS={{ matrix.allowed_users | join(',') if matrix.allowed_users is iterable and matrix.allowed_users is not string else matrix.allowed_users }}
{% endif %}
{% if matrix.allowed_rooms is defined %}
MATRIX_ALLOWED_ROOMS={{ matrix.allowed_rooms | join(',') if matrix.allowed_rooms is iterable and matrix.allowed_rooms is not string else matrix.allowed_rooms }}
{% endif %}
{% if matrix.home_room is defined %}
MATRIX_HOME_ROOM={{ matrix.home_room }}
{% endif %}
{% endif %}
