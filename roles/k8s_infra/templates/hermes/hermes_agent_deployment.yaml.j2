{# Per-user Hermes Agent Deployment (the official `hermes dashboard` UI).
   Standalone pod — webui (if enabled) lives in its own deployment.
   Both pods are pinned to k3smaster and share the same NFS subdir hostPath
   so /opt/data (sessions/skills/configs) is identical across them.
#}
{#- /workspace gate: when enabled, /workspace is a seadrive FUSE mount of the
    user's Seafile `hermes-workspace` library (shared with the webui pod via
    the Seafile server, with a sync lag of a few seconds). When disabled,
    /workspace is the legacy NFS subdir hostPath. -#}
{%- set _seafile = item.seafile | default({}) -%}
{%- set _seafile_workspace = (_seafile.get('workspace_enabled', hermes.seafile.workspace_enabled_default)) | bool -%}
{#- Messaging-gateway gate: the `hermes gateway run` sidecar lives in THIS
    (agent) pod whenever the dashboard is enabled, so the dashboard can show
    gateway liveness via the in-pod HTTP health probe. The webui pod only hosts
    the gateway when the dashboard is OFF (see hermes_webui_deployment.yaml.j2)
    — exactly one gateway runs, so the two never contend on the
    /opt/data/gateway.lock flock. -#}
{%- set _email = item.email | default({}) -%}
{%- set _email_enabled = _email.get('enabled', hermes.email.enabled_default) -%}
{%- set _matrix = item.matrix | default({}) -%}
{%- set _matrix_enabled = _matrix.get('enabled', hermes.matrix.enabled_default) -%}
{%- set _gateway_enabled = (_email_enabled or _matrix_enabled) -%}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "hermes-agent-{{ item.username }}"
  namespace: "{{ hermes.namespace }}"
  labels:
    app: hermes
    hermes-component: agent
    hermes-user: "{{ item.username }}"
  annotations:
    # Keel auto-update: poll DockerHub for newer tags. The agent ships SemVer
    # tags (vYYYY.M.D), so `minor` lets keel pull both date-bumps and patch
    # bumps but never crosses an intentional major. Daily poll is plenty.
    keel.sh/policy: minor
    keel.sh/match-tag: "true"
    keel.sh/pollSchedule: "@every 24h"
    keel.sh/trigger: poll
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: hermes
      hermes-component: agent
      hermes-user: "{{ item.username }}"
  template:
    metadata:
      labels:
        app: hermes
        hermes-component: agent
        hermes-user: "{{ item.username }}"
      annotations:
        # Default container for `kubectl logs`/`exec` — skips initContainer noise
        kubectl.kubernetes.io/default-container: hermes
        # Auto-roll the pod when the seed config.yaml or .env changes
        # (e.g. flipping `hermes_debug` or rotating the litellm token).
        # The merge-config initContainer needs to run again to push the new
        # values into /opt/data/{config.yaml,.env}; without these annotations
        # the ConfigMap/Secret update alone leaves the pod on stale settings.
        checksum/config: "{{ lookup('template', 'hermes/hermes_config.yaml.j2') | hash('sha256') }}"
        checksum/env:    "{{ lookup('template', 'hermes/hermes_env.j2')         | hash('sha256') }}"
        # Roll the pod when the per-profile seed (spec + secrets) changes so
        # merge-config re-seeds /opt/data/profiles/<name>/ on next start.
        checksum/profiles: "{{ (lookup('template', 'hermes/hermes_profiles_spec.json.j2') ~ lookup('template', 'hermes/hermes_profiles_secrets.json.j2')) | hash('sha256') }}"
        # Roll the pod when the merge-config script changes so the new merge
        # logic runs against /opt/data on next start.
        checksum/merge:  "{{ lookup('file', 'hermes_merge_config.py') | hash('sha256') }}"
        # Hash the raw login secret so rotating basicauth_password forces a
        # fresh pod: it now drives the dashboard's BasicAuthProvider via the
        # DASHBOARD_BASIC_AUTH_PASSWORD/SECRET Secret keys, and a Secret change
        # does NOT auto-roll the pod. Hash the cleartext (the value is otherwise
        # only Secret-referenced) — stable across runs, unlike a re-salted hash.
        checksum/auth:   "{{ (item.basicauth_password | default(item.litellm_token)) | hash('sha256') }}"
        # ALWAYS emit gated checksums with the gate flag folded into the value —
        # never wrap them in a Jinja if/endif block. A disable (enabled->disabled) must still
        # CHANGE the annotation so the pod rolls; dropping the key relies on the
        # apply pruning a nested-map key, which it does NOT do reliably (same class
        # as the stale nodeSelector keys documented in CLAUDE.md). The referenced
        # files are always on disk, so hashing them while disabled is harmless.
        #
        # email-patch: subPath ConfigMap mounts don't surface updates without a
        # restart. Consumed by the hermes-gateway sidecar (below), same as webui.
        checksum/email-patch: "{{ _email_enabled | bool }}:{{ lookup('file', 'hermes_email_gateway_patched.py') | hash('sha256') }}"
        # seafile: rolls the pod to add/drop the seadrive sidecar and to pick up
        # rotated creds (hermes-seafile-<user> Secret is envFrom, read at start).
        checksum/seafile: "{{ _seafile_workspace }}:{{ (hermes.seafile.server_url ~ '|' ~ (item.email.address | default('?')) ~ '|' ~ (item.seafile.web_password | default('none'))) | hash('sha256') }}"
        # gateway: rolls the pod to add/drop the hermes-gateway sidecar (and the
        # api_server /health the dashboard probes). Folded flag, not an if/endif.
        checksum/gateway: "{{ _gateway_enabled | bool }}"
        # themes: rolls the pod so init-dashboard-themes re-copies an updated
        # shipped theme YAML into /opt/data/dashboard-themes/.
        checksum/themes: "{{ lookup('file', 'hermes_dashboard_theme_cyberpunk_lg.yaml') | hash('sha256') }}"
    spec:
      restartPolicy: Always
{% if _gateway_enabled %}
      # MUST stay false: the hermes-gateway sidecar runs the agent image's
      # s6-overlay /init, and s6-overlay-suexec refuses to start unless it is
      # PID 1. shareProcessNamespace would make the pause container PID 1 and
      # crashloop the sidecar. Consequence: the dashboard can't use the
      # same-PID-namespace os.kill() liveness on the gateway PID, so it detects
      # the gateway via the in-pod HTTP health probe (GATEWAY_HEALTH_URL) plus
      # the shared /opt/data/gateway_state.json — no shared PID ns needed.
      # Explicit false (not omitted) so kubernetes.core.k8s strategic-merge
      # can't leave a stale `true` behind.
      shareProcessNamespace: false
{% endif %}
      nodeSelector:
        node-role: k3smaster
      securityContext:
        runAsUser: {{ item.uid }}
        runAsGroup: {{ item.gid }}
        fsGroup: {{ item.gid }}
        runAsNonRoot: true
      initContainers:
        # hostPath DirectoryOrCreate creates 0755 root:root; reset to <uid>:<gid> 0700.
        - name: fix-perms
          image: busybox:latest
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
          command:
            - sh
            - -c
{% if _seafile_workspace %}
            # /workspace is FUSE-managed by the seadrive sidecar — POSIX
            # owner is set by seadrive's mount options. Only fix /opt/data.
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data && chmod 0700 /opt/data"
{% else %}
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data /workspace && chmod 0700 /opt/data /workspace"
{% endif %}
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
{% if not _seafile_workspace %}
            - name: files
              mountPath: /workspace
{% endif %}
        # Strategic merge of ops-managed keys into /opt/data/config.yaml +
        # /opt/data/.env. Script lives in roles/k8s_dgx/files/hermes_merge_config.py
        # (ConfigMap hermes-merge-config, mounted at /opt/merge-config); see its
        # header for the full rationale (bind-mount EBUSY, key-preservation
        # strategy, litellm api_key injection). UID/GID are passed via env so the
        # file stays static/cluster-wide.
        #
        # Uses the agent image because it already has PyYAML in its venv and
        # is guaranteed cached on the node (used by the main container too).
        - name: merge-config
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
          command:
            - /opt/hermes/.venv/bin/python
            - /opt/merge-config/hermes_merge_config.py
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: MERGE_UID
              value: "{{ item.uid }}"
            - name: MERGE_GID
              value: "{{ item.gid }}"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: merge-config
              mountPath: /opt/merge-config
              readOnly: true
            - name: seed-config
              mountPath: /seed-config
              readOnly: true
            - name: seed-secret
              mountPath: /seed-secret
              readOnly: true
        # Install shipped dashboard themes into $HERMES_HOME/dashboard-themes/
        # where `_discover_user_themes()` reads them. We COPY (not subPath-mount
        # the ConfigMap onto the dir) so the directory stays writable and any
        # user-created themes there survive. Overwrites the shipped ones each
        # start so an updated theme YAML propagates. chown to the runtime uid.
        - name: init-dashboard-themes
          image: busybox:latest
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
          command:
            - sh
            - -c
            - "mkdir -p /opt/data/dashboard-themes && cp /seed-themes/*.yaml /opt/data/dashboard-themes/ && chown -R {{ item.uid }}:{{ item.gid }} /opt/data/dashboard-themes"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: dashboard-themes
              mountPath: /seed-themes
              readOnly: true
        # 2026-06-11: copy-ui-tui disabled for a test deploy — the pinned
        # v2026.6.5 image contains both PR #33045 (entrypoint chowns
        # $INSTALL_DIR/ui-tui + node_modules after the UID remap) and the
        # build-time `npm_config_install_links=false` that neutralises the
        # `_tui_need_npm_install()` lockfile-mismatch trigger. See
        # UPSTREAM_HERMES_AGENT_TUI_BUG.md (Action Items). If the dashboard
        # logs "npm install failed" / "Chat unavailable: 1" again, re-enable
        # this initContainer plus the `ui-tui` volumeMount and volume below.
        #
        # Original rationale (pre-v0.15.0 images): `hermes dashboard --tui`
        # runs `npm install` on every launch because `_tui_need_npm_install()`
        # returns True (the upstream image has a package-lock vs
        # node_modules/.package-lock content mismatch). The image-baked
        # /opt/hermes/ui-tui/node_modules is root-owned, so the rename(2) npm
        # uses to swap directories EACCES's for our non-root UID — including
        # under the entrypoint pattern, since pre-#33045 entrypoints only
        # chowned $HERMES_HOME, not /opt/hermes/.
        # - name: copy-ui-tui
        #   image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
        #   command:
        #     - sh
        #     - -c
        #     - "cp -a /opt/hermes/ui-tui/. /target/ && chown -R {{ item.uid }}:{{ item.gid }} /target"
        #   securityContext:
        #     runAsUser: 0
        #     runAsNonRoot: false
        #   volumeMounts:
        #     - name: ui-tui
        #       mountPath: /target
        # RETIRED: seeded Caddy's writable user-DB. The Caddy auth sidecar is
        # replaced by hermes' built-in BasicAuthProvider, so there is no
        # users.json to seed. Commented out (not deleted) for easy rollback
        # together with the caddy sidecar + volumes below.
        # - name: init-caddy-data
        #   image: busybox:latest
        #   env:
        #     - name: TZ
        #       value: "{{ hermes.timezone }}"
        #   command:
        #     - sh
        #     - -c
        #     - "cp /seed/users.json /caddy-data/users.json && chown {{ item.uid }}:{{ item.gid }} /caddy-data/users.json && chmod 0600 /caddy-data/users.json"
        #   securityContext:
        #     runAsUser: 0
        #     runAsNonRoot: false
        #   volumeMounts:
        #     - name: caddy-secret
        #       mountPath: /seed
        #       readOnly: true
        #     - name: caddy-data
        #       mountPath: /caddy-data
      containers:
{% if _seafile_workspace %}
        # ===== seadrive FUSE sidecar =========================================
        # Mirrors the same sidecar in hermes-webui — see that file for the
        # design rationale. Both pods mount the same Seafile library via
        # independent seadrive instances; the Seafile server is the source
        # of truth, with a few-seconds sync lag between the pods.
        - name: seadrive
          image: "{{ hermes.seadrive.image }}:{{ hermes.seadrive.image_tag }}"
          imagePullPolicy: IfNotPresent
          securityContext:
            privileged: true
            runAsUser: 0
            runAsGroup: 0
            runAsNonRoot: false
          envFrom:
            - secretRef:
                name: "hermes-seafile-{{ item.username }}"
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: WANTED_UID
              value: "{{ item.uid }}"
            - name: WANTED_GID
              value: "{{ item.gid }}"
            - name: SEAFILE_LIBRARY_NAME
              value: "{{ hermes.seafile.library_name }}"
          # Entrypoint script is shared with the webui pod's identical seadrive
          # sidecar — roles/k8s_dgx/files/hermes_seadrive_start.sh (ConfigMap
          # hermes-seadrive, mounted at /opt/seadrive).
          command:
            - /bin/bash
            - /opt/seadrive/hermes_seadrive_start.sh
          volumeMounts:
            - name: seadrive-entrypoint
              mountPath: /opt/seadrive
              readOnly: true
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: Bidirectional
          lifecycle:
            preStop:
              exec:
                command:
                  - /bin/sh
                  - -c
                  - "umount /workspace 2>/dev/null || true; fusermount -u /seadrive 2>/dev/null || true"
          resources:
            requests:
              cpu: "20m"
              memory: "64Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
{% endif %}
        - name: hermes
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
          imagePullPolicy: Always
          # Overrides the image WORKDIR (/opt/hermes). main-wrapper.sh sets the
          # process cwd to `${HERMES_ORIG_CWD:-$PWD}` before exec'ing `hermes
          # dashboard`; its with-contenv shebang is bypassed in the CMD path so
          # HERMES_ORIG_CWD isn't loaded and it falls back to $PWD. workingDir
          # makes $PWD = /workspace, so the dashboard process cwd (and thus the
          # `!`-shell's os.getcwd() + the TUI footer) lands in /workspace.
          workingDir: "{{ item.terminal_cwd | default(hermes.terminal_cwd) }}"
          # We let the image's default ENTRYPOINT run instead of overriding
          # `command:`. Since v2026.5.28 that ENTRYPOINT is s6-overlay's /init
          # (pre-s6 it was /opt/hermes/docker/entrypoint.sh, now a deprecated
          # shim). The s6 flow preserves the old contract 1:1 ("Architecture B"):
          #   1. /init runs as root, cont-init script stage2-hook.sh usermod's
          #      the baked-in `hermes` user (UID 10000) to HERMES_UID/HERMES_GID
          #      and chown's HERMES_HOME + .venv + ui-tui.
          #   2. docker/main-wrapper.sh (the CMD wrapper) sources the venv,
          #      cd's /opt/data, sets HOME=/opt/data, then drops via
          #      `s6-setuidgid hermes` (replaces the old `gosu hermes`).
          #      $HERMES_HOME dir-seed (cron/sessions/logs/.../.env/SOUL.md/
          #      skills_sync) is done by stage2-hook under s6-setuidgid.
          #   3. If $1 is an executable on PATH → exec it raw; otherwise
          #      → exec hermes "$@". So `args: [dashboard, --host, ...]`
          #      becomes `s6-setuidgid hermes hermes dashboard --host ...`.
          # NB: the image also auto-starts two s6 services — `main-hermes`
          # (a no-op `sleep infinity` slot) and `dashboard` (gated OFF unless
          # HERMES_DASHBOARD is truthy, which we do NOT set) — so neither
          # collides with our CMD dashboard on 9119.
          # That gives us a /etc/passwd entry for our UID (so HOME is set,
          # which fixes npm cache EACCES), pre-created data dirs, SOUL.md,
          # and bundled-skills sync — all of which our previous explicit
          # `command:` override skipped.
          #
          # Bind to 127.0.0.1: Caddy sidecar (same network namespace)
          # connects via 127.0.0.1:9119 — `ws.client.host` arrives as
          # 127.0.0.1 which matches Hermes' built-in _LOOPBACK_HOSTS.
          # `--insecure` not needed (Hermes only requires it for non-
          # loopback binds).
          args:
            - "dashboard"
            # Bind 0.0.0.0 (was 127.0.0.1 behind the retired Caddy sidecar).
            # Non-loopback bind → `should_require_auth` engages hermes' built-in
            # BasicAuthProvider (configured via HERMES_DASHBOARD_BASIC_AUTH_* env
            # below), AND `_is_accepted_host` returns True for 0.0.0.0 so the WS
            # Host/Origin guard accepts the public Origin (no Caddy Origin
            # rewrite needed). `--insecure` only PERMITS the non-loopback bind;
            # since the hermes-0day fix it no longer disables auth.
            # - "--host=127.0.0.1"   # retired with the Caddy auth sidecar
            - "--host={{ hermes.agent.bind_host }}"
            - "--insecure"
            - "--port={{ hermes.agent.dashboard_port }}"
            - "--no-open"
            # NOTE: the `--tui` flag was REMOVED upstream in v0.16.0 /
            # hermes.image_tag v2026.6.5 (PR #38591, merged 2026-06-04) — the
            # dashboard chat is on by default now. Passing it aborts with
            # "unrecognized arguments: --tui" → crash-loop, so nothing is
            # emitted here. The former per-user `dashboard_tui` gate (a no-op on
            # v0.16.0+) was dropped 2026-07. Re-add a real flag here if/when
            # upstream lands a replacement. See UPSTREAM_HERMES_AGENT_TUI_BUG.md.
          # Container-level securityContext overrides pod-level. /init MUST
          # start as root to do the usermod + s6-setuidgid drop. After the
          # drop, the python process runs as <uid> matching pod-level intent.
          securityContext:
            runAsUser: 0
            runAsGroup: 0
            runAsNonRoot: false
          env:
            # Local time for dashboard timestamps (image defaults to UTC).
            - name: TZ
              value: "{{ hermes.timezone }}"
            # Read by cont-init stage2-hook.sh: `usermod -u $HERMES_UID hermes`.
            # After this the s6-setuidgid-spawned hermes process runs as <uid>
            # with a proper /etc/passwd entry (HOME=/opt/data is set explicitly
            # by main-wrapper.sh before the privilege drop).
            - name: HERMES_UID
              value: "{{ item.uid }}"
            - name: HERMES_GID
              value: "{{ item.gid }}"
            # Working directory for the agent's file-tools + `!`-shell. config.yaml
            # `terminal.cwd` alone is NOT enough for the dashboard: hermes bridges
            # it to the TERMINAL_CWD env only on a COPY of os.environ for the
            # spawned TUI subprocess (web_server.py apply_terminal_config_to_env
            # on `os.environ.copy()`), so the IN-PROCESS chat agent's file_tools —
            # which read `os.environ["TERMINAL_CWD"]` directly — never see it and
            # fall back to the process cwd (/opt/hermes). Setting it on the
            # container puts it in os.environ for every context. No deprecation
            # warning fires because config.yaml still declares terminal.cwd.
            - name: TERMINAL_CWD
              value: "{{ item.terminal_cwd | default(hermes.terminal_cwd) }}"
            # Process cwd of the dashboard. The `!`-shell RPC (tui_gateway
            # shell.exec) runs commands with `cwd=os.getcwd()`, and the TUI
            # footer shows the process cwd — NEITHER honours terminal.cwd, so
            # both land in the image WORKDIR /opt/hermes. The image's
            # main-wrapper.sh cd's to `${HERMES_ORIG_CWD:-$PWD}` before exec'ing
            # `hermes dashboard` (the "-w" mechanism), so this makes the whole
            # process start in /workspace → `!pwd`, footer AND file-tools align.
            - name: HERMES_ORIG_CWD
              value: "{{ item.terminal_cwd | default(hermes.terminal_cwd) }}"
            # --- dashboard built-in auth (BasicAuthProvider) ---
            # The 0.0.0.0 bind requires an auth provider; these env vars make
            # hermes auto-register the username/password provider at startup
            # (it registers iff username AND password are set). Env wins over
            # config.yaml, so no dashboard.basic_auth block is needed there.
            # Username is non-secret; password + signing secret come from the
            # per-user Secret (see the Render hermes Secret task).
            - name: HERMES_DASHBOARD_BASIC_AUTH_USERNAME
              value: "{{ item.username }}"
            - name: HERMES_DASHBOARD_BASIC_AUTH_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: "hermes-env-{{ item.username }}"
                  key: DASHBOARD_BASIC_AUTH_PASSWORD
            # Stable token-signing key → sessions survive pod restarts.
            - name: HERMES_DASHBOARD_BASIC_AUTH_SECRET
              valueFrom:
                secretKeyRef:
                  name: "hermes-env-{{ item.username }}"
                  key: DASHBOARD_BASIC_AUTH_SECRET
{% if _gateway_enabled %}
            # Cross-container gateway liveness for the dashboard's "Gateway"
            # badge: probe the in-pod gateway api_server /health (same pod,
            # localhost). DEPRECATED env-var surface upstream (to be folded into
            # a dashboard config key) but the ONLY cross-container mechanism
            # today — the PID-based check needs a shared PID ns, which the s6
            # gateway sidecar forbids. Re-check on image bumps.
            - name: GATEWAY_HEALTH_URL
              value: "http://127.0.0.1:{{ hermes.agent.gateway_api_port }}"
            - name: GATEWAY_HEALTH_TIMEOUT
              value: "3"
{% endif %}
          ports:
            - containerPort: {{ hermes.agent.dashboard_port }}
              name: dashboard
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "{{ item.cpu_limit | default('2') }}"
              memory: "{{ item.memory_limit | default('2Gi') }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
{% if _seafile_workspace %}
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: HostToContainer
{% else %}
            - name: files
              mountPath: /workspace
{% endif %}
            # 2026-06-11: ui-tui overlay disabled together with the
            # copy-ui-tui initContainer (see its comment block above) — the
            # v2026.6.5 image tree is expected to work as baked.
            # - name: ui-tui
            #   mountPath: /opt/hermes/ui-tui
          # Probe against loopback via python (the agent image has no
          # curl/wget). Hermes now binds 0.0.0.0 so a kubelet tcpSocket probe
          # on the pod IP would also work, but the in-container loopback exec
          # is kept — it's port-accurate and independent of pod networking.
          livenessProbe:
            exec:
              command:
                - "/opt/hermes/.venv/bin/python3"
                - "-c"
                - "import socket;socket.create_connection(('127.0.0.1',{{ hermes.agent.dashboard_port }}),1).close()"
            initialDelaySeconds: 60
            periodSeconds: 30
            failureThreshold: 5
          readinessProbe:
            exec:
              command:
                - "/opt/hermes/.venv/bin/python3"
                - "-c"
                - "import socket;socket.create_connection(('127.0.0.1',{{ hermes.agent.dashboard_port }}),1).close()"
            initialDelaySeconds: 15
            periodSeconds: 10
        # RETIRED: Caddy + caddy-security auth sidecar. Replaced by hermes'
        # built-in BasicAuthProvider (dashboard bound to 0.0.0.0, see the args +
        # HERMES_DASHBOARD_BASIC_AUTH_* env on the hermes container). Kept
        # commented out (with the init-caddy-data init + caddy-* volumes) for
        # rollback. It terminated auth as an HMAC-JWT cookie and reverse-proxied
        # to localhost:9119; caddy-security validated the cookie only on the
        # initial handshake so WS/EventSource passed through (the reason we left
        # oauth2-proxy, which 403'd every WS upgrade).
        # - name: caddy
        #   image: "{{ hermes.caddy.image }}:{{ item.caddy_image_tag | default(hermes.caddy.image_tag) }}"
        #   imagePullPolicy: IfNotPresent
        #   command: ["caddy"]
        #   args: ["run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
        #   env:
        #     - name: TZ
        #       value: "{{ hermes.timezone }}"
