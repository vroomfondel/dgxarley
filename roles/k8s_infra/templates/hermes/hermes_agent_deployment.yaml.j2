{% if _gateway_enabled %}
        # Messaging-gateway sidecar — `hermes gateway run` auto-starts every
        # platform whose creds are in /opt/data/.env (Email EMAIL_*, Matrix
        # MATRIX_*, …) AND the api_server platform (enabled in config.yaml),
        # whose 127.0.0.1:{{ hermes.agent.gateway_api_port }}/health the
        # dashboard container probes (GATEWAY_HEALTH_URL) for the "Gateway"
        # badge. Shares /opt/data with the dashboard (same sessions/skills/.env
        # + gateway_state.json). Uses the agent image (the `hermes` CLI); its s6
        # /init drops root→uid. No HTTP port exposed on the pod — health is
        # localhost-only. shareProcessNamespace stays false (s6 needs PID 1), so
        # the dashboard uses the HTTP probe, not a same-ns PID check.
        - name: hermes-gateway
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
          imagePullPolicy: Always
          # Same as the dashboard container: make $PWD = /workspace so the
          # gateway process (and any agent it spawns) starts there.
          workingDir: "{{ item.terminal_cwd | default(hermes.terminal_cwd) }}"
          args:
            - "gateway"
            - "run"
          securityContext:
            runAsUser: 0
            runAsGroup: 0
            runAsNonRoot: false
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: HERMES_UID
              value: "{{ item.uid }}"
            - name: HERMES_GID
              value: "{{ item.gid }}"
            # Shared /opt/data so gateway.pid / gateway.lock / gateway_state.json
            # land where the dashboard container reads them.
            - name: HERMES_HOME
              value: "/opt/data"
            # Same reason as the dashboard container: anchor gateway-originated
            # agent file-tools to /workspace, not the process cwd.
            - name: TERMINAL_CWD
              value: "{{ item.terminal_cwd | default(hermes.terminal_cwd) }}"
            # main-wrapper cd's here before `hermes gateway run` → gateway
            # process cwd = /workspace (matches the dashboard container).
            - name: HERMES_ORIG_CWD
              value: "{{ item.terminal_cwd | default(hermes.terminal_cwd) }}"
            # api_server needs a >=16-char key to start (connect() refuses
            # otherwise). localhost-only in-pod; the /health probe is
            # unauthenticated so the dashboard never sends it.
            - name: API_SERVER_KEY
              valueFrom:
                secretKeyRef:
                  name: "hermes-env-{{ item.username }}"
                  key: GATEWAY_API_SERVER_KEY
            - name: API_SERVER_PORT
              value: "{{ hermes.agent.gateway_api_port }}"
          resources:
            requests:
              cpu: "20m"
              memory: "128Mi"
            limits:
              cpu: "{{ (item.gateway | default({})).get('cpu_limit', _email.get('cpu_limit', '500m')) }}"
              memory: "{{ (item.gateway | default({})).get('memory_limit', _email.get('memory_limit', '512Mi')) }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
{% if _seafile_workspace %}
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: HostToContainer
{% else %}
            - name: files
              mountPath: /workspace
{% endif %}
{% if _email_enabled %}
            # dgxarley local patch over plugins/platforms/email/adapter.py
            # (Working/Done lifecycle, IMAP APPEND, PROCESS_EXISTING) — same
            # subPath mount as the webui pod's gateway. Re-sync on image bump.
            - name: hermes-email-patch
              mountPath: /opt/hermes/plugins/platforms/email/adapter.py
              subPath: adapter.py
              readOnly: true
{% endif %}
{% endif %}
        # Tail agent.log onto stdout so `kubectl logs -c log-tail <pod>` works
        # without execing into the pod. Inherits the pod-level securityContext
        # (runs as <uid>:<gid>) and reads /opt/data RO. Logs don't exist until
        # hermes first writes them, so wait for the file before exec'ing tail.
        - name: log-tail
          image: busybox:latest
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
          command:
            - sh
            - -c
            - |
              until [ -f /opt/data/logs/agent.log ]; do sleep 2; done
              exec tail -n 0 -F /opt/data/logs/agent.log
          resources:
            requests:
              cpu: "10m"
              memory: "16Mi"
            limits:
              cpu: "100m"
              memory: "64Mi"
          volumeMounts:
            - name: data
              mountPath: /opt/data
              readOnly: true
      volumes:
        - name: data
          hostPath:
            path: "{{ hermes.data_base }}/{{ item.username }}"
            type: DirectoryOrCreate
{% if _seafile_workspace %}
        # /workspace is FUSE-managed by the seadrive sidecar; the emptyDir
        # just provides a shared mountpoint across containers in the pod.
        - name: workspace-fuse
          emptyDir: {}
        - name: seadrive-entrypoint
          configMap:
            name: hermes-seadrive
{% else %}
        # User-managed input/output shelf, mounted at /workspace. Same per-user
        # NFS subdir isolation as the data volume.
        - name: files
          hostPath:
            path: "{{ hermes.files_base }}/{{ item.username }}"
            type: DirectoryOrCreate
{% endif %}
        - name: merge-config
          configMap:
            name: hermes-merge-config
        - name: dashboard-themes
          configMap:
            name: hermes-dashboard-themes
        - name: seed-config
          configMap:
            name: "hermes-config-{{ item.username }}"
        - name: seed-secret
          secret:
            secretName: "hermes-env-{{ item.username }}"
{% if _email_enabled %}
        # Single-file patch mount for the gateway sidecar's email adapter —
        # same ConfigMap the webui pod uses. Rendered by hermes.yml.
        - name: hermes-email-patch
          configMap:
            name: hermes-email-patch
            items:
              - key: adapter.py
                path: adapter.py
{% endif %}
