{# Per-user Hermes WebUI Deployment (ghcr.io/nesquena/hermes-webui).
   Runs in its own pod next to the agent pod. Both share the same NFS subdir
   hostPath as /opt/data — sessions/skills/configs are visible to both UIs.
   The WebUI still spawns its own `hermes` subprocesses for chat/tools (see
   upstream limitation #681); the agent pod's running process is independent.

   Optional `hermes-gateway` sidecar (gated on _gateway_enabled = any platform
   enabled): runs `hermes gateway run` from the agent image, which auto-starts
   EVERY messaging platform whose credentials are present in /opt/data/.env —
   one process serves Email (EMAIL_*) AND Matrix (MATRIX_*) etc. simultaneously.
   Outbound mail/messages also work through tool-calls inside webui-spawned
   hermes subprocesses, which inherit the same /opt/data/.env — no extra wiring.
#}
{%- set _email = item.email | default({}) -%}
{%- set _email_enabled = _email.get('enabled', hermes.email.enabled_default) -%}
{#- Matrix gateway gate (env-driven: MATRIX_* in .env, no source patch needed,
    unlike email which overlays plugins/platforms/email/adapter.py). E2EE crypto store lives on
    the /opt/data NFS subdir so device keys persist across restarts. -#}
{%- set _matrix = item.matrix | default({}) -%}
{%- set _matrix_enabled = _matrix.get('enabled', hermes.matrix.enabled_default) -%}
{#- The gateway sidecar (+ state refresher) runs here ONLY when the dashboard
    is disabled. When the dashboard is on, its pod hosts the single gateway (so
    the dashboard can probe gateway liveness in-pod) and this webui pod must NOT
    start a second one — two `hermes gateway run` processes would contend on the
    /opt/data/gateway.lock flock. Extend the platform OR-chain when adding
    further platforms (telegram, slack, …). -#}
{%- set _dashboard_enabled = item.dashboard_enabled | default(hermes.agent.dashboard_enabled_default) -%}
{%- set _gateway_enabled = (_email_enabled or _matrix_enabled) and not _dashboard_enabled -%}
{#- /workspace gate: seadrive-mounted Seafile library vs NFS subdir hostPath.
    When enabled, the `files` volume becomes an emptyDir + a privileged
    seadrive FUSE sidecar bind-mounts the user's `hermes-workspace` lib onto
    it. Per-user override via item.seafile.workspace_enabled. -#}
{%- set _seafile = item.seafile | default({}) -%}
{%- set _seafile_workspace = (_seafile.get('workspace_enabled', hermes.seafile.workspace_enabled_default)) | bool -%}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "hermes-webui-{{ item.username }}"
  namespace: "{{ hermes.namespace }}"
  labels:
    app: hermes
    hermes-component: webui
    hermes-user: "{{ item.username }}"
  annotations:
    # Keel auto-update: ghcr.io/nesquena/hermes-webui ships only `:latest`,
    # so `force` + `match-tag` redeploys whenever the digest behind :latest
    # changes upstream. Daily poll matches the rest of the cluster.
    keel.sh/policy: force
    keel.sh/match-tag: "true"
    keel.sh/pollSchedule: "@every 24h"
    keel.sh/trigger: poll
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: hermes
      hermes-component: webui
      hermes-user: "{{ item.username }}"
  template:
    metadata:
      labels:
        app: hermes
        hermes-component: webui
        hermes-user: "{{ item.username }}"
      annotations:
        # Default container for `kubectl logs`/`exec` — skips initContainer noise
        kubectl.kubernetes.io/default-container: hermes-webui
        # Auto-roll the pod when the seed config.yaml or .env changes
        # (e.g. flipping `hermes_debug` or rotating the litellm token).
        # Same shared ConfigMap/Secret as the agent pod — both initContainers
        # need to re-merge into /opt/data on update.
        checksum/config:      "{{ lookup('template', 'hermes/hermes_config.yaml.j2') | hash('sha256') }}"
        checksum/env:         "{{ lookup('template', 'hermes/hermes_env.j2')         | hash('sha256') }}"
        # Roll the pod when the shared merge-config script changes.
        checksum/merge:       "{{ lookup('file', 'hermes_merge_config.py') | hash('sha256') }}"
        # Roll on per-profile seed changes (webui-only users have no agent pod, so
        # this pod's merge-config is what seeds /opt/data/profiles/<name>/).
        checksum/profiles:    "{{ (lookup('template', 'hermes/hermes_profiles_spec.json.j2') ~ lookup('template', 'hermes/hermes_profiles_secrets.json.j2')) | hash('sha256') }}"
        # Hash the raw login secret so rotating basicauth_password (which is
        # only referenced by the Caddy users.json ConfigMap and the
        # WEBUI_PASSWORD Secret key — neither of which triggers a pod
        # rollover on its own) forces a fresh pod. Hash the cleartext, not
        # the bcrypt output: bcrypt re-salts on every render, which would
        # cause a spurious rollover on every playbook run.
        checksum/auth:        "{{ (item.basicauth_password | default(item.litellm_token)) | hash('sha256') }}"
        # ALWAYS emit gated checksums with the gate flag folded into the value —
        # never wrap them in a Jinja if/endif block. A disable (enabled->disabled) must still
        # CHANGE the annotation so the pod rolls; dropping the key relies on the
        # apply pruning a nested-map key, which it does NOT do reliably (same class
        # as the stale nodeSelector keys documented in CLAUDE.md). The referenced
        # files are always on disk, so hashing them while disabled is harmless.
        #
        # email-patch: subPath ConfigMap mounts don't surface updates without a restart.
        checksum/email-patch: "{{ _email_enabled | bool }}:{{ lookup('file', 'hermes_email_gateway_patched.py') | hash('sha256') }}"
        # health-patch: same subPath-doesn't-update reason. Rolls the pod when the
        # gateway health-endpoint patch changes (gateway only).
        checksum/health-patch: "{{ _gateway_enabled | bool }}:{{ lookup('file', 'hermes_health_patch.py') | hash('sha256') }}"
        # gw-refresh: rolls the pod to add/drop the gateway sidecar and pick up a
        # changed refresher script.
        checksum/gw-refresh:  "{{ _gateway_enabled | bool }}:{{ lookup('file', 'hermes_gateway_state_refresher.py') | hash('sha256') }}"
        # seafile: rolls the pod to add/drop the seadrive sidecar and to pick up
        # rotated creds (hermes-seafile-<user> Secret is envFrom, read at start).
        checksum/seafile:     "{{ _seafile_workspace }}:{{ (hermes.seafile.server_url ~ '|' ~ (item.email.address | default('?')) ~ '|' ~ (item.seafile.web_password | default('none'))) | hash('sha256') }}"
    spec:
      restartPolicy: Always
      # MUST stay false: the hermes-gateway sidecar runs the agent image's
      # s6-overlay /init entrypoint (since v2026.5.28), and s6-overlay-suexec
      # refuses to start unless it is PID 1 ("fatal: can only run as pid 1").
      # shareProcessNamespace makes the pause-container PID 1, so enabling it
      # crashloops the gateway sidecar. The two are mutually exclusive; s6 wins
      # (it performs the hermes-user drop), so PID-namespace sharing is OFF.
      #
      # Trade-off: this disables the #1879 cross-container gateway-liveness fix
      # (WebUI's api/agent_health.py does os.kill(pid, 0) on the gateway PID
      # from gateway_state.json). Without a shared PID ns that check fails and
      # the WebUI falls back to a 120 s freshness check on gateway_state.json
      # — only a cosmetic "Gateway not configured" badge if the file goes
      # stale; the IMAP/SMTP gateway process itself polls/sends fine regardless.
      #
      # Explicit `false` (not a removed key) because kubernetes.core.k8s does a
      # strategic-merge: a deleted field would NOT prune the live `true`.
      shareProcessNamespace: false
      nodeSelector:
        node-role: k3smaster
      # Pod-level securityContext: the webui image's hermeswebui_init.bash
      # entrypoint REQUIRES starting as root (UID 0). It then `usermod`s the
      # baked-in `hermeswebui` user to WANTED_UID/WANTED_GID, prepares root-
      # owned paths (/app, $UV_CACHE_DIR, /opt/data), and `exec su`s itself
      # to `hermeswebui`. The python server runs as {{ item.uid }}/{{ item.gid }}.
      #
      # Earlier image versions (pre-2026-05-15) shipped sudo + a separate
      # hermeswebuitoo user (UID 1025) that did the bootstrap and dropped
      # to hermeswebui (UID 1024). The new production image dropped sudo
      # entirely; the bootstrap now ONLY runs when whoami == root, otherwise
      # the script aborts with `current UID 1025 ≠ wanted ${WANTED_UID}`.
      # See script: `if [ "A${whoami}" == "Aroot" ]; then ... usermod ...
      # exec su -s /bin/bash -c "exec ..." hermeswebui`.
      #
      # fsGroup={{ item.gid }} so the post-switch hermeswebui user can read
      # the NFS-mounted /opt/data; the bootstrap as root doesn't need it.
      securityContext:
        runAsUser: 0
        runAsGroup: 0
        fsGroup: {{ item.gid }}
        runAsNonRoot: false
      initContainers:
        # Reset NFS subdir owner so the post-switch hermeswebui user (UID
        # {{ item.uid }}) can write. Idempotent — agent pod's fix-perms does the
        # same thing; whichever runs first wins, the other is a no-op.
        - name: fix-perms
          image: busybox:latest
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
          command:
            - sh
            - -c
{% if _seafile_workspace %}
            # /workspace is FUSE-managed by the seadrive sidecar — POSIX
            # owner is set by seadrive's mount options. Only fix /opt/data.
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data && chmod 0700 /opt/data"
{% else %}
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data /workspace && chmod 0700 /opt/data /workspace"
{% endif %}
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
{% if not _seafile_workspace %}
            - name: files
              mountPath: /workspace
{% endif %}
        # Strategic merge of ops-managed keys into /opt/data/config.yaml +
        # /opt/data/.env (+ /opt/data/.webui/settings.json). Shares the exact
        # script with the hermes-agent pod's merge-config initContainer —
        # roles/k8s_dgx/files/hermes_merge_config.py (ConfigMap
        # hermes-merge-config, mounted at /opt/merge-config); see its header for
        # the full EBUSY rationale. Needed here because the webui spawns its own
        # `hermes` subprocesses reading the same config.yaml/.env. Race-safe
        # because both pods derive the same ops-managed values from the same
        # ConfigMap/Secret. UID/GID via env; WEBUI_SETTINGS_B64 additionally
        # drives the WebUI settings.json merge (agent pod omits it).
        - name: merge-config
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
          command:
            - /opt/hermes/.venv/bin/python
            - /opt/merge-config/hermes_merge_config.py
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: MERGE_UID
              value: "{{ item.uid }}"
            - name: MERGE_GID
              value: "{{ item.gid }}"
            # base64 of the per-user webui_settings JSON; empty/`{}` → the
            # settings.json merge is skipped inside the script.
            - name: WEBUI_SETTINGS_B64
              value: "{{ item.webui_settings | default({}) | to_json | b64encode }}"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: merge-config
              mountPath: /opt/merge-config
              readOnly: true
            - name: seed-config
              mountPath: /seed-config
              readOnly: true
            - name: seed-secret
              mountPath: /seed-secret
              readOnly: true
        # Provide the hermes-agent source tree to the webui. Upstream's
        # docker-compose.two-container.yml does the same via a named volume
        # (`hermes-agent-src`) populated from the agent image; we replicate it
        # with an emptyDir + initContainer copy so the webui pod is self-
        # contained (no cross-pod volume coupling). The webui's docker_init.bash
        # then runs `uv pip install <agent-src>[all]` against this dir.
        - name: copy-agent-src
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
          command:
            - sh
            - -c
            # Also write a VERSION file with the image tag — upstream's
            # _detect_agent_version() (api/updates.py:145) looks for
            # <agent_dir>/VERSION first, falls back to `git describe` in the
            # source tree. The Docker image ships neither, so without this
            # the System page shows "Agent: not detected" even though the
            # agent code is fully present and functional. Use the resolved
            # image tag as the version label.
            - "cp -a /opt/hermes/. /agent-src/ && printf '%s\\n' '{{ item.image_tag | default(hermes.image_tag) }}' > /agent-src/VERSION && chown -R {{ item.uid }}:{{ item.gid }} /agent-src"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: agent-src
              mountPath: /agent-src
      containers:
{% if _seafile_workspace %}
        # ===== seadrive FUSE sidecar =========================================
        # Mounts the user's `hermes-workspace` Seafile library as /workspace,
        # shared with the other containers in this pod via a Bidirectional
        # mountPropagation on an emptyDir. Requires privileged + /dev/fuse.
        #
        # Sequence:
        #   1. Render seadrive.conf from the hermes-seafile-<user> Secret
        #   2. Launch seadrive in the background, mounting all libs at
        #      /seadrive — `hermes-workspace` appears at /seadrive/hermes-workspace
        #   3. Wait for that subdir to materialise (FUSE async cache)
        #   4. bind-mount it onto /workspace (the shared emptyDir mount point);
        #      via Bidirectional propagation this becomes visible to webui +
        #      hermes-email containers as their /workspace contents.
        #   5. wait on the seadrive process; preStop unmounts cleanly.
        - name: seadrive
          image: "{{ hermes.seadrive.image }}:{{ hermes.seadrive.image_tag }}"
          imagePullPolicy: IfNotPresent
          securityContext:
            privileged: true
            runAsUser: 0
            runAsNonRoot: false
          envFrom:
            - secretRef:
                name: "hermes-seafile-{{ item.username }}"
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: WANTED_UID
              value: "{{ item.uid }}"
            - name: WANTED_GID
              value: "{{ item.gid }}"
            - name: SEAFILE_LIBRARY_NAME
              value: "{{ hermes.seafile.library_name }}"
          # Entrypoint script is shared with the agent pod's identical seadrive
          # sidecar — roles/k8s_dgx/files/hermes_seadrive_start.sh (ConfigMap
          # hermes-seadrive, mounted at /opt/seadrive).
          command:
            - /bin/bash
            - /opt/seadrive/hermes_seadrive_start.sh
          volumeMounts:
            - name: seadrive-entrypoint
              mountPath: /opt/seadrive
              readOnly: true
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: Bidirectional
          lifecycle:
            preStop:
              exec:
                command:
                  - /bin/sh
                  - -c
                  - "umount /workspace 2>/dev/null || true; fusermount -u /seadrive 2>/dev/null || true"
          resources:
            requests:
              cpu: "20m"
              memory: "64Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
{% endif %}
        - name: hermes-webui
          image: "{{ hermes.webui.image }}:{{ item.webui_image_tag | default(hermes.webui.image_tag) }}"
          imagePullPolicy: IfNotPresent
          env:
            # Render server-side timestamps ("Last active" in System Status) in
            # local time. The image defaults to UTC → 2h off CEST without this.
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: HERMES_WEBUI_HOST
              value: "0.0.0.0"
            - name: HERMES_WEBUI_PORT
              value: "{{ hermes.webui.port }}"
            - name: HERMES_HOME
              value: "/opt/data"
            - name: HERMES_WEBUI_AGENT_DIR
              value: "/opt/agent-src"
            - name: HERMES_WEBUI_STATE_DIR
              value: "/opt/data/.webui"
            # Persist uv's wheel cache on the per-user data hostPath (local
            # ext4) instead of the ephemeral overlay default (/uv_cache). The
            # nesquena image does NOT bundle hermes-agent's runtime deps
            # (dotenv/requests/httpx); docker_init.bash reinstalls agent[all]
            # into the ephemeral /app/venv on every pod start. A persistent
            # cache makes that reinstall fast (cached wheels, no re-download).
            # NOT persisting /app/venv itself: the webui image is unpinned
            # (:latest), and a python-version change would leave a broken venv.
            - name: UV_CACHE_DIR
              value: "/opt/data/.uv-cache"
            # Auto-install hermes-agent runtime deps (dotenv, etc.) into the
            # webui venv on first start. Without this, "run_agent" features
            # break with ModuleNotFoundError; web UI itself still loads.
            - name: HERMES_WEBUI_AUTO_INSTALL
              value: "1"
            # Branding so the user knows whose dashboard they're on. Default
            # "Hermes (<username>)" — overridable via vault `webui_bot_name`.
            # Shown next to every assistant message in the chat.
            - name: HERMES_WEBUI_BOT_NAME
              value: "{{ item.webui_bot_name | default('Hermes (' ~ item.username ~ ')') }}"
            # Pin the default model in the model picker to our LiteLLM-backed
            # one. Empty would let the WebUI fall back to whatever provider
            # defaults exist (often an OpenAI model that's unavailable here, #646).
            - name: HERMES_WEBUI_DEFAULT_MODEL
              value: "{{ (item.litellm_model | default('')) or hermes.default_model }}"
            - name: WANTED_UID
              value: "{{ item.uid }}"
            - name: WANTED_GID
              value: "{{ item.gid }}"
            - name: HERMES_WEBUI_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: "hermes-env-{{ item.username }}"
                  key: WEBUI_PASSWORD
          ports:
            - containerPort: {{ hermes.webui.port }}
              name: webui
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "{{ item.webui_cpu_limit | default('1') }}"
              memory: "{{ item.webui_memory_limit | default('1Gi') }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: agent-src
              mountPath: /opt/agent-src
            # Same agent-src volume ALSO mounted at /opt/hermes — docker_init.bash
            # only auto-installs hermes-agent[all] (dotenv/requests/httpx) if it
            # finds the source at the hardcoded /opt/hermes or
            # ~/.hermes/hermes-agent. Our HERMES_WEBUI_AGENT_DIR=/opt/agent-src is
            # NOT one of those, so without this the base install is skipped (with a
            # "hermes-agent source not found" warning) and run_agent only gets its
            # deps via the slow lazy fallback. Mounting here makes the base install
            # find it → no missing-modules warning, deps present from first boot.
            - name: agent-src
              mountPath: /opt/hermes
{% if _seafile_workspace %}
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: HostToContainer
{% else %}
            - name: files
              mountPath: /workspace
{% endif %}
          livenessProbe:
            httpGet:
              path: /health
              port: {{ hermes.webui.port }}
            initialDelaySeconds: 90
            periodSeconds: 30
            failureThreshold: 5
          readinessProbe:
            httpGet:
              path: /health
              port: {{ hermes.webui.port }}
            initialDelaySeconds: 30
            periodSeconds: 10
{% if _gateway_enabled %}
        # Messaging-gateway sidecar — runs `hermes gateway run`, which auto-starts
        # EVERY platform whose credentials are present in /opt/data/.env (merged
        # by the merge-config init): Email (EMAIL_*, IMAP poll + SMTP dispatch),
        # Matrix (MATRIX_*, sync loop + optional E2EE), etc. — one process, all
        # platforms. Uses the agent image because the `hermes` CLI lives there.
        # The image's /init (s6-overlay since v2026.5.28) usermod's the baked-in
        # `hermes` user to HERMES_UID/GID via cont-init, then main-wrapper.sh
        # `s6-setuidgid hermes`-drops before exec'ing `hermes gateway run`
        # (pre-s6 this was the entrypoint + gosu). No HTTP port — the gateway
        # is daemon-only; rely on K8s restart-on-crash for liveness.
        # Shares /opt/data with the webui container so both see the same
        # sessions/skills/.env. Outbound mail/messages from webui-spawned hermes
        # subprocesses also work via the same .env, no extra wiring needed.
        - name: hermes-gateway
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
          imagePullPolicy: Always
          args:
            - "gateway"
            - "run"
          securityContext:
            runAsUser: 0
            runAsGroup: 0
            runAsNonRoot: false
          env:
            # Local time for gateway timestamps/logs (image defaults to UTC).
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: HERMES_UID
              value: "{{ item.uid }}"
            - name: HERMES_GID
              value: "{{ item.gid }}"
            # Pin HERMES_HOME into the shared /opt/data hostPath so the
            # gateway writes its gateway.pid / gateway_state.json / state.db
            # where the webui pod can see them. Without this the sidecar
            # falls back to a container-local default (~/.hermes) and the
            # webui's /api/gateway/status always reports "Gateway not
            # configured" — and gateway-originated sessions (Email etc.)
            # never appear in the WebUI session list (see #1879).
            - name: HERMES_HOME
              value: "/opt/data"
            # config.yaml enables the api_server platform whenever a gateway
            # runs; connect() refuses to start it without a >=16-char key. Set
            # it here too so this sidecar (used only when the dashboard is off)
            # starts api_server cleanly. localhost-only in-pod.
            - name: API_SERVER_KEY
              valueFrom:
                secretKeyRef:
                  name: "hermes-env-{{ item.username }}"
                  key: GATEWAY_API_SERVER_KEY
            - name: API_SERVER_PORT
              value: "{{ hermes.agent.gateway_api_port }}"
          resources:
            requests:
              cpu: "20m"
              memory: "128Mi"
            limits:
              cpu: "{{ item.gateway.cpu_limit | default(item.email.cpu_limit | default('500m')) }}"
              memory: "{{ item.gateway.memory_limit | default(item.email.memory_limit | default('512Mi')) }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
{% if _seafile_workspace %}
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: HostToContainer
{% else %}
            - name: files
              mountPath: /workspace
{% endif %}
            # Health-endpoint patch (.py + .pth) into the venv site dir → makes
            # this gateway's /health/detailed public so the dashboard probe stops
            # logging a per-poll 401. subPath so siblings in site-packages survive.
            - name: hermes-health-patch
              mountPath: "{{ hermes.venv_site_packages }}/hermes_health_patch.py"
              subPath: hermes_health_patch.py
              readOnly: true
            - name: hermes-health-patch
              mountPath: "{{ hermes.venv_site_packages }}/zz_hermes_health_patch.pth"
              subPath: zz_hermes_health_patch.pth
              readOnly: true
{% if _email_enabled %}
            # dgxarley local patch — overlays the upstream plugins/platforms/
            # email/adapter.py with the version under
            # roles/k8s_infra/files/hermes_email_gateway_patched.py.  Adds
            # Working/Done folder lifecycle, IMAP APPEND to Sent, and the
            # EMAIL_PROCESS_EXISTING knob (see file's PATCH header).
            # subPath gives us a single-file bind mount — the rest of
            # /opt/hermes (venv, ui-tui, hooks, etc.) stays untouched from
            # the image. Pin: file content must match the upstream source
            # of hermes.image_tag; re-sync on image bump. Matrix needs no
            # equivalent patch (pure-env platform), so it's gated on email only.
            # NOTE: upstream #41112 MOVED this file at v2026.7.1 — it was
            # /opt/hermes/gateway/platforms/email.py through v2026.6.19.
            - name: hermes-email-patch
              mountPath: /opt/hermes/plugins/platforms/email/adapter.py
              subPath: adapter.py
              readOnly: true
{% endif %}
        # Gateway-status refresher — keeps the WebUI "Gateway configured" badge
        # green WHILE the gateway genuinely runs (any platform). The agent only writes
        # gateway_state.json on lifecycle changes, so its updated_at goes stale
        # within 120 s and the WebUI's freshness check (api/agent_health.py)
        # flips to "not configured". We can't use the upstream cross-container
        # os.kill(pid,0) liveness because shareProcessNamespace must stay false
        # (s6 in the gateway sidecar needs PID 1). Instead this sidecar bumps
        # updated_at periodically, gated on the SAME crash-safe flock the gateway
        # holds for its lifetime (kernel auto-releases it on OOM/SIGKILL → we
        # stop refreshing → badge correctly goes stale). command: overrides the
        # agent image's s6 /init (this helper needs no hermes-user drop; it runs
        # directly as the per-user uid and only touches uid-owned /opt/data).
        # Purely cosmetic: the IMAP/SMTP gateway itself is unaffected either way.
        - name: gateway-state-refresh
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes.image_tag) }}"
          imagePullPolicy: Always
          command:
            - /opt/hermes/.venv/bin/python
            - /opt/gw-refresh/hermes_gateway_state_refresher.py
          securityContext:
            runAsUser: {{ item.uid }}
            runAsGroup: {{ item.gid }}
            runAsNonRoot: true
          env:
            - name: TZ
              value: "{{ hermes.timezone }}"
            - name: HERMES_HOME
              value: "/opt/data"
            - name: REFRESH_INTERVAL_S
              value: "10"
          resources:
            requests:
              cpu: "5m"
              memory: "32Mi"
            limits:
              cpu: "50m"
              memory: "64Mi"
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: hermes-gw-refresh
              mountPath: /opt/gw-refresh
              readOnly: true
{% endif %}
      volumes:
        - name: data
          hostPath:
            path: "{{ hermes.data_base }}/{{ item.username }}"
            type: DirectoryOrCreate
{% if _seafile_workspace %}
        # /workspace is FUSE-managed by the seadrive sidecar; the emptyDir
        # just provides a shared mountpoint across containers in the pod.
        - name: workspace-fuse
          emptyDir: {}
        - name: seadrive-entrypoint
          configMap:
            name: hermes-seadrive
{% else %}
        # User-managed input/output shelf, mounted at /workspace. Same per-user
        # NFS subdir isolation as the data volume.
        - name: files
          hostPath:
            path: "{{ hermes.files_base }}/{{ item.username }}"
            type: DirectoryOrCreate
{% endif %}
        - name: agent-src
          emptyDir: {}
        - name: merge-config
          configMap:
            name: hermes-merge-config
        - name: seed-config
          configMap:
            name: "hermes-config-{{ item.username }}"
        - name: seed-secret
          secret:
            secretName: "hermes-env-{{ item.username }}"
{% if _gateway_enabled %}
        # Gateway api_server health-patch (.py + .pth) — subPath-mounted into the
        # venv site dir of the gateway sidecar. Shared ConfigMap; rendered by
        # hermes.yml. Present whenever a gateway runs in this pod.
        - name: hermes-health-patch
          configMap:
            name: hermes-health-patch
            items:
              - key: hermes_health_patch.py
                path: hermes_health_patch.py
              - key: zz_hermes_health_patch.pth
                path: zz_hermes_health_patch.pth
{% endif %}
{% if _email_enabled %}
        - name: hermes-email-patch
          configMap:
            name: hermes-email-patch
            items:
              - key: adapter.py
                path: adapter.py
{% endif %}
{% if _gateway_enabled %}
        - name: hermes-gw-refresh
          configMap:
            name: hermes-gw-refresh
            items:
              - key: hermes_gateway_state_refresher.py
                path: hermes_gateway_state_refresher.py
{% endif %}
