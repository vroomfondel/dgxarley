{# Hermes Agent config — rendered per user via lookup('template', ...).
   Provider "custom" routes through an OpenAI-compatible API (LiteLLM).
   NOTE: model.api_key is deliberately NOT set here — this file becomes the
   non-secret ConfigMap. The merge-config initContainer patches model.api_key
   in at startup from the Secret-backed .env (OPENAI_API_KEY). It MUST end up in
   config (not just .env) because Hermes host-gates OPENAI_API_KEY to
   openai.com/azure (GHSA / #28660) and the WebUI auxiliary_client reads the key
   from config, not os.environ. See the merge-config block in the deployments.
   See: https://hermes-agent.nousresearch.com/docs/user-guide/configuration
#}
model:
  provider: "custom"
  default: "{{ (item.litellm_model | default('')) or hermes.default_model }}"
  base_url: "{{ hermes.litellm_url }}/v1"
{% set _context_length = (item.context_length | default('')) or (hermes.context_length | default('')) or (_hermes_default_context_length | default('')) %}
{% if _context_length %}
  # Pinned context window. hermes-default is a LiteLLM alias with no probe-able
  # context metadata, so without this Hermes defaults to 256,000 ("probe-down"
  # INFO in agent.log). Value precedence: per-user item.context_length →
  # ops override hermes.context_length → DERIVED from the active SGLang model
  # profile (sglang_model_profiles[sglang_model].context_length, set in hermes.yml).
  # The derived path tracks a model swap automatically; the overrides are escape
  # hatches. Empty everywhere → key omitted → Hermes' 256k auto-default.
  context_length: {{ _context_length }}
{% endif %}
{% set vision_model = (item.vision_model | default('')) or hermes.vision_model %}
{% if vision_model %}

# Auxiliary VISION model for image tasks (vision_analyze). The main model
# (hermes-default → SGLang) is text-only, so Hermes routes image description to
# this aux model. No `provider:` — for auxiliary slots `base_url` takes
# precedence over provider (upstream docs), and the documented custom-endpoint
# form is base_url + api_key + model only; `provider: custom` is the main-model
# (model:) idiom, not the auxiliary one. The model is a LiteLLM alias
# (vision-default → sglang-vision companion). api_key is NOT set here (non-secret
# ConfigMap) — the merge-config initContainer patches auxiliary.vision.api_key
# from the Secret-backed .env (OPENAI_API_KEY = the per-user litellm_token), same
# reason as model.api_key (Hermes host-gates OPENAI_API_KEY to openai.com/azure,
# so an env fallback would not authenticate against our litellm.* base_url).
auxiliary:
  vision:
    model: "{{ vision_model }}"
    base_url: "{{ hermes.litellm_url }}/v1"
{% endif %}
{% set _custom_providers = item.custom_providers | default([]) %}
{% if _custom_providers %}

# ADDITIONAL, user-selectable backends (Hermes' native top-level custom_providers).
# Each appears in the `hermes model` picker; switch mid-session with the triple
# syntax provider:model. These do NOT change model.default (the LiteLLM-backed
# hermes-default main model). api_key is deliberately NOT set here (this file is the
# non-secret ConfigMap): the merge-config initContainer injects each entry's
# api_key at startup from CUSTOM_PROVIDER_<NAME>_API_KEY in the Secret .env
# (name-derived), keeping keys out of the ConfigMap. Inline api_key (not key_env)
# per the deployment design; Hermes resolves key_env first, else inline api_key
# (hermes_cli/runtime_provider.py). Set `key_env` on an entry to opt out of the
# injection and have Hermes read that env var directly.
custom_providers:
{% for cp in _custom_providers %}
  - name: "{{ cp.name }}"
    base_url: "{{ cp.base_url }}"
{% if cp.api_mode is defined %}
    api_mode: "{{ cp.api_mode }}"
{% endif %}
{% if cp.model is defined %}
    model: "{{ cp.model }}"
{% endif %}
{% if cp.key_env is defined %}
    key_env: "{{ cp.key_env }}"
{% endif %}
{% endfor %}
{% endif %}

terminal:
  backend: "local"
  # Working directory for `!`-shell commands + agent file-tools (what `!pwd`
  # shows). "." resolves to the process cwd, which is the read-only image
  # WORKDIR /opt/hermes for the dashboard — so pin an absolute path. Default
  # /workspace = the per-user file shelf (hostPath, or the seadrive Seafile
  # mount). NOT $HOME/HERMES_HOME (/opt/data) — that holds hermes internals.
  # config.yaml is the canonical surface; the TERMINAL_CWD env var is deprecated.
  cwd: "{{ item.terminal_cwd | default(hermes.terminal_cwd) }}"
  timeout: 180

# Web-dashboard visual defaults. Only theme+font are ops-managed here; the
# deep-merge in hermes_merge_config.py preserves any OTHER dashboard.* keys the
# user sets via the Preferences panel (e.g. show_token_analytics). NOTE: a
# user's in-UI theme/font change is reset to these values on the next pod
# restart (ops wins) — move to a per-user override if that's unwanted.
dashboard:
  theme: "{{ item.dashboard_theme | default(hermes.dashboard_theme) }}"
  font: "{{ item.dashboard_font | default(hermes.dashboard_font) }}"

# Web search via in-cluster SearXNG (search-only). SEARXNG_URL is set in .env.
# Extract/crawl backends are not configured — Hermes' web_extract / web_crawl
# will be unavailable until a Firecrawl/Tavily/Exa key is added.
web:
  backend: "searxng"

# Server-side log level for /opt/data/logs/agent.log. The merge-config
# initContainer always rewrites this on pod start, so toggling
# `hermes_debug` on a user entry and rolling the pod is enough — ops wins.
logging:
  level: "{{ 'DEBUG' if (item.hermes_debug | default(hermes.debug_default)) else 'INFO' }}"
{% set email = item.email | default({}) %}
{% set matrix = item.matrix | default({}) %}
{% set _email_on = email.get('enabled', hermes.email.enabled_default) %}
{% set _gateway_on = _email_on or matrix.get('enabled', hermes.matrix.enabled_default) %}
{% if _gateway_on %}

# Messaging-gateway platform config, read by `hermes gateway run` (the sidecar
# in the dashboard pod, or the webui pod when the dashboard is off).
platforms:
  # api_server: the gateway's aiohttp server on 127.0.0.1:<API_SERVER_PORT>.
  # Its UNAUTHENTICATED GET /health is what the dashboard probes
  # (GATEWAY_HEALTH_URL) for the cross-container "Gateway" badge. The key + port
  # come from the sidecar env (API_SERVER_KEY / API_SERVER_PORT); connect()
  # refuses to start the server without a >=16-char key.
  api_server:
    enabled: true
{% if _email_on %}
  # Email gateway (IMAP/SMTP) — credentials live in /opt/data/.env as EMAIL_*.
  # Outbound mail also goes through tool-calls in UI-spawned hermes
  # subprocesses, which inherit the same .env.
  email:
    # Behavioral toggles MUST live under `extra:` — the gateway config loader
    # only folds `platforms.<name>.extra` into PlatformConfig.extra (which the
    # adapter reads via extra.get(...)); bare keys here are silently dropped.
    # Verified on pinned image v2026.6.5 and on upstream main.
    extra:
      skip_attachments: {{ (email.skip_attachments | default(false)) | string | lower }}
      # INBOX → Working → Done folder lifecycle. Mirrors upstream PR #28702.
      # working_folder="" skips the Working stage (INBOX → Done directly);
      # done_folder="" disables all moves (INBOX + \Seen, and Working is skipped
      # too). Quoted so an empty string renders as "" rather than a YAML null.
      working_folder: "{{ email.working_folder if email.working_folder is defined else 'Hermes_Working' }}"
      done_folder: "{{ email.done_folder if email.done_folder is defined else 'Hermes_Done' }}"
      # IMAP APPEND target for outbound replies; "" → SMTP-only (opt-out).
      # Mirrors upstream PR NousResearch/hermes-agent#28697. Quoted so an empty
      # string renders as "" rather than a YAML null.
      sent_folder: "{{ email.sent_folder if email.sent_folder is defined else 'Sent' }}"
      # Process the pre-existing UNSEEN INBOX backlog on startup instead of
      # marking it all seen. Mirrors upstream PR #28699. Default true here
      # (upstream defaults false). Rendered as a real YAML bool.
      process_existing: {{ (email.process_existing | default(true)) | string | lower }}
    # Suppress "♻️ Gateway shutting down" / "♻️ Gateway online" lifecycle
    # mails. Hermes sends these to every active session + the EMAIL_HOME_ADDRESS
    # home channel on each pod start/stop; pure noise here. (Bridged as a bare
    # key — gateway_restart_notification is on the loader's shared-key allowlist
    # and also read directly by PlatformConfig.from_dict, unlike the toggles
    # above.)
    gateway_restart_notification: false
{% endif %}
{% endif %}
