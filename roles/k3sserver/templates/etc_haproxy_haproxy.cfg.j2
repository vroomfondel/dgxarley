global
	log /dev/log	daemon  # local0 debug
	# log /dev/log	local1 debug
	chroot /var/lib/haproxy
	stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
	stats timeout 30s
	user haproxy
	group haproxy
	daemon

	# Default SSL material locations
	ca-base /etc/ssl/certs
	crt-base /etc/ssl/private

	# See: https://ssl-config.mozilla.org/#server=haproxy&server-version=2.0.3&config=intermediate
        ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384
        ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
        ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets

defaults
	log	global
	mode	http
	option	httplog
	option	dontlognull
        timeout connect 5000
        timeout client  1800000
        timeout server  1800000
	errorfile 400 /etc/haproxy/errors/400.http
	errorfile 403 /etc/haproxy/errors/403.http
	errorfile 408 /etc/haproxy/errors/408.http
	errorfile 500 /etc/haproxy/errors/500.http
	errorfile 502 /etc/haproxy/errors/502.http
	errorfile 503 /etc/haproxy/errors/503.http
	errorfile 504 /etc/haproxy/errors/504.http
        log-format "%ci:%cp [%t] %ft %b/%s %Tq/%Tw/%Tc/%Tr/%Ta %ST %B %CC %CS %tsc %ac/%fc/%bc/%sc/%rc %sq/%bq %hr %hs %{+Q}r"



frontend haproxystats
    bind 127.0.0.1:8123
    stats enable
    stats auth admin:{{ haproxy_stats_password | default('changeme') }}
    # echo stats will be available here: http://127.0.0.1:8123/haproxy?stats ; ssh -L 8123:127.0.0.1:8123 -N root@acerrevo.local

# ---------------------------------------------------------------------
# Frontend für HTTP (Port 80)
# ---------------------------------------------------------------------
frontend k3s_http_front
    bind *:80
    mode tcp
    option tcplog
    default_backend k3s_http_back

#frontend k3s_http_front2
#    bind *:81
#    mode tcp
#    option tcplog
#    default_backend k3s_http_back


# ---------------------------------------------------------------------
# Frontend für HTTPS (Port 443)
# ---------------------------------------------------------------------
frontend k3s_https_front
    bind *:443
    mode tcp
    option tcplog
    default_backend k3s_https_back


# ---------------------------------------------------------------------
# Backend für HTTP
# send-proxy-v2 aktiviert das Proxy Protocol für Traefik
# ---------------------------------------------------------------------
backend k3s_http_back
    mode tcp
    balance roundrobin
    # Ersetze <K3S_NODE_IP> durch die IP deines K3s Nodes
    # Port 80 ist der Standard NodePort/HostPort für Traefik in K3s
    server k3s-node-1 127.0.0.1:30080 send-proxy-v2 check

# ---------------------------------------------------------------------
# Backend für HTTPS
# send-proxy-v2 aktiviert das Proxy Protocol für Traefik
# ---------------------------------------------------------------------
backend k3s_https_back
    mode tcp
    balance roundrobin
    # Ersetze <K3S_NODE_IP> durch die IP deines K3s Nodes
    # Port 443 ist der Standard NodePort/HostPort für SSL in K3s
    server k3s-node-1-https 127.0.0.1:30443 send-proxy-v2 check

    # Optional: Wenn du mehrere K3s Nodes hast, füge sie hier hinzu:
    # server k3s-node-2 <K3S_NODE_2_IP>:443 send-proxy-v2 check


# check roles/k3sserver/files/traefik-extend.yaml for ports/proxy_protocol enabled ports there
