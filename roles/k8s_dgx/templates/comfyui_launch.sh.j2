# Make $APP visible to Python's site.py so sitecustomize.py is auto-loaded
# at interpreter init. Set this only for the launch — pip installs above
# this point have already finished, so they aren't affected.
export PYTHONPATH="$APP:${PYTHONPATH:-}"

# --- 5. Launch -----------------------------------------------------
# Debian/Ubuntu bases ship only `python3`; a `python` alias only exists
# when the python-is-python3 package is installed. Resolve through PATH
# so exec doesn't fail with "python: not found".
#
# --use-sage-attention: global attention backend = SageAttention v2.
# Background: xformers' own FMHA dispatcher does not know about SM_121
# (Blackwell GB10) and rejects the sm80-family kernels with
#   FATAL: kernel '..._sm80' is for sm80-sm100, but was built for sm121
# even when the binary is technically sm80-compatible. The FA3 path
# (Hopper) has no loadable SASS for sm121 at all. Sage delivers better
# throughput on Blackwell anyway and is verified functional on sm121
# (bf16, multi-head). Until the xformers patches (see
# COMFYUI_SM121_PATCHES.md) are baked into the image, Sage is the only
# functional custom backend.
PY="$(command -v python3 || command -v python)"
echo "[comfyui] launching on 0.0.0.0:{{ comfyui_port }} ($PY)"

# Filter cosmetic FATAL noise from PyTorch's CUTLASS kernel selector.
# On sm121 (Blackwell GB10), PyTorch's `aten::_efficient_attention_forward`
# probes its kernel table and prints
#   FATAL: kernel `fmha_cutlassF_*_sm80` is for sm80-sm100, but was built for sm121
# for every entry that doesn't match before settling on a viable kernel
# (typically fa2F-pt). It's not a crash — verified by the integration test
# (8/8 pass) — but each VAE attention call emits ~30 of these lines, which
# floods the pod log. The printf is below TORCH_CPP_LOG_LEVEL and can't be
# silenced via env var. The message comes from a C-level `printf(...)` and
# therefore lands on stdout (fd 1), not stderr — verified empirically:
# triggering EFFICIENT_ATTENTION on fp32 produced 2048 lines on fd 1 and 0
# on fd 2. Filtering only fd 2 was a no-op. We now filter both fds. Pattern
# is narrow: only `^FATAL: kernel ` is dropped, every other FATAL/error
# line still passes through. `--line-buffered` keeps multi-line tracebacks
# intact. Documented in COMFYUI_SM121_PATCHES.md ("Cosmetic FATAL noise").
exec > >(grep --line-buffered -v '^FATAL: kernel ')
exec 2> >(grep --line-buffered -v '^FATAL: kernel ' >&2)

exec "$PY" main.py \
  --listen 0.0.0.0 \
  --port {{ comfyui_port }} \
  --use-sage-attention \
  --highvram \
  --output-directory "$DATA/output" \
  --temp-directory "$DATA/temp"

# --highvram on DGX Spark (GB10, unified memory) — design notes:
#
# DGX Spark uses a unified-memory architecture: the Grace ARM CPU and
# the Blackwell GPU share the same physical LPDDR5X pool (~128 GB per
# node). Unlike a discrete GPU where "VRAM" and "host RAM" are
# separate physical pools connected by PCIe, here both views map to
# the same memory. ComfyUI's default "smart memory" mode is designed
# around the dGPU model — it actively offloads model weights between
# "GPU memory" and "host memory" to fit a small VRAM budget, paying
# real PCIe transfer cost on a discrete card. On unified memory that
# offloading is essentially free in terms of *data movement*, but
# ComfyUI still pays the *software* cost: per-forward bookkeeping,
# CUDA allocator updates, and the per-iteration loop seen in the log:
#   loaded partially; 6978 MB loaded, 4371 MB offloaded   ← smart memory
# That ~3 s/iter for FLUX (vs ~0.5–1 s/iter when fully resident) is
# almost entirely software overhead, not data transfer.
#
# `--highvram` tells ComfyUI to keep loaded models entirely in the GPU
# view and never partial-offload, eliminating the per-iteration
# bookkeeping. On unified memory this gives the same effect as a
# dGPU's full-VRAM-load case without the data-transfer cost on the
# offload path — i.e. it's almost always the right setting on this
# hardware.
#
# Caveat — GPU time-slicing: when 4-fold time-slicing is enabled (each
# physical GPU appears as 4 logical replicas), ComfyUI sees only its
# share of the unified pool as "GPU memory" via cudaMemGetInfo(). With
# `--highvram` ComfyUI will reserve its full slice up front and not
# release it back, even when idle. If a co-tenant pod (e.g. SGLang)
# needs more memory at the same time, it gets the OOM, not us. If you
# care about co-tenancy more than ComfyUI's own latency, drop the flag
# (revert to "smart memory" / `--normalvram`); if ComfyUI runs alone
# on the GPU or you'd rather have throughput than fairness, keep it.
#
# OOM behaviour: with `--highvram`, a model that doesn't fit will
# crash the workflow rather than silently fall back to slow streaming.
# That's almost always preferable for debugging — the failure points
# at the real constraint (model size vs. budget) instead of hiding it
# in a 5x slowdown.