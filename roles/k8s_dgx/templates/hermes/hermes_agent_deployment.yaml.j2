{# Per-user Hermes Agent Deployment (the official `hermes dashboard` UI).
   Standalone pod — webui (if enabled) lives in its own deployment.
   Both pods are pinned to k3smaster and share the same NFS subdir hostPath
   so /opt/data (sessions/skills/configs) is identical across them.
#}
{%- set _dashboard_tui = item.dashboard_tui | default(hermes_dashboard_tui_default) -%}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "hermes-agent-{{ item.username }}"
  namespace: "{{ hermes_namespace }}"
  labels:
    app: hermes
    hermes-component: agent
    hermes-user: "{{ item.username }}"
  annotations:
    # Keel auto-update: poll DockerHub for newer tags. The agent ships SemVer
    # tags (vYYYY.M.D), so `minor` lets keel pull both date-bumps and patch
    # bumps but never crosses an intentional major. Daily poll is plenty.
    keel.sh/policy: minor
    keel.sh/match-tag: "true"
    keel.sh/pollSchedule: "@every 24h"
    keel.sh/trigger: poll
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: hermes
      hermes-component: agent
      hermes-user: "{{ item.username }}"
  template:
    metadata:
      labels:
        app: hermes
        hermes-component: agent
        hermes-user: "{{ item.username }}"
      annotations:
        # Default container for `kubectl logs`/`exec` — skips initContainer noise
        kubectl.kubernetes.io/default-container: hermes
        # Auto-roll the pod when the seed config.yaml or .env changes
        # (e.g. flipping `hermes_debug` or rotating the litellm token).
        # The merge-config initContainer needs to run again to push the new
        # values into /opt/data/{config.yaml,.env}; without these annotations
        # the ConfigMap/Secret update alone leaves the pod on stale settings.
        checksum/config: "{{ lookup('template', 'hermes/hermes_config.yaml.j2') | hash('sha256') }}"
        checksum/env:    "{{ lookup('template', 'hermes/hermes_env.j2')         | hash('sha256') }}"
    spec:
      restartPolicy: Always
      nodeSelector:
        node-role: k3smaster
      securityContext:
        runAsUser: {{ item.uid }}
        runAsGroup: {{ item.gid }}
        fsGroup: {{ item.gid }}
        runAsNonRoot: true
      initContainers:
        # hostPath DirectoryOrCreate creates 0755 root:root; reset to <uid>:<gid> 0700.
        - name: fix-perms
          image: busybox:1.37
          command:
            - sh
            - -c
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data && chmod 0700 /opt/data"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
        # Strategic merge of ops-managed keys into /opt/data/config.yaml +
        # /opt/data/.env. We can NOT mount them as subPath of a ConfigMap/Secret
        # directly — that makes them bind-mounts, and Hermes'
        # `atomic_yaml_write()` does rename(2) over the target which fails with
        # EBUSY on bind-mounts (the original 2026 trace was triggered by a
        # Settings → Theme save).
        #
        # Strategy: every top-level key present in the seed (provider, default-
        # model, base_url for config.yaml; OPENAI_API_KEY for .env) is enforced
        # on every pod start. Keys the user added (theme, tool toggles, extra
        # provider keys) are preserved. Lets ops update the cluster default and
        # propagate to existing pods on next restart, while still letting users
        # customise non-managed bits in the WebUI without losing their work.
        #
        # Uses the agent image because it already has PyYAML in its venv and
        # is guaranteed cached on the node (used by the main container too).
        - name: merge-config
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes_image_tag) }}"
          command:
            - /opt/hermes/.venv/bin/python
            - -c
            - |
              import os, yaml
              UID, GID = {{ item.uid }}, {{ item.gid }}
              def deep_override(user, ops):
                  for k, v in ops.items():
                      if isinstance(v, dict) and isinstance(user.get(k), dict):
                          deep_override(user[k], v)
                      else:
                          user[k] = v
              # config.yaml — strategic merge
              ops = yaml.safe_load(open("/seed-config/config.yaml")) or {}
              try:
                  user = yaml.safe_load(open("/opt/data/config.yaml")) or {}
              except FileNotFoundError:
                  user = {}
              deep_override(user, ops)
              with open("/opt/data/config.yaml", "w") as f:
                  yaml.safe_dump(user, f, sort_keys=False)
              os.chown("/opt/data/config.yaml", UID, GID)
              os.chmod("/opt/data/config.yaml", 0o600)
              # .env — KEY=VALUE merge (ops wins for managed keys, others kept)
              def parse_env(p):
                  out = {}
                  if not os.path.exists(p):
                      return out
                  for line in open(p):
                      s = line.strip()
                      if not s or s.startswith("#") or "=" not in s:
                          continue
                      k, v = s.split("=", 1)
                      out[k.strip()] = v
                  return out
              ops_env = parse_env("/seed-secret/.env")
              user_env = parse_env("/opt/data/.env")
              user_env.update(ops_env)
              with open("/opt/data/.env", "w") as f:
                  for k, v in user_env.items():
                      f.write(f"{k}={v}\n")
              os.chown("/opt/data/.env", UID, GID)
              os.chmod("/opt/data/.env", 0o600)
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: seed-config
              mountPath: /seed-config
              readOnly: true
            - name: seed-secret
              mountPath: /seed-secret
              readOnly: true
        # Seed Caddy's writable user-DB from the read-only Secret. Always
        # overwrite on start so password rotations in vault propagate. Caddy
        # itself may write to this file (admin bootstrap, password resets) but
        # we are deliberately ephemeral about that — Ansible is the source of
        # truth, in-pod edits survive only until the next restart.
        - name: init-caddy-data
          image: busybox:1.37
          command:
            - sh
            - -c
            - "cp /seed/users.json /caddy-data/users.json && chown {{ item.uid }}:{{ item.gid }} /caddy-data/users.json && chmod 0600 /caddy-data/users.json"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: caddy-secret
              mountPath: /seed
              readOnly: true
            - name: caddy-data
              mountPath: /caddy-data
      containers:
        - name: hermes
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes_image_tag) }}"
          imagePullPolicy: IfNotPresent
          # `dashboard` serves the web UI on 9119; --tui adds the embedded chat tab.
          # `gateway run` (the docker default) is messaging-only and binds no
          # HTTP port — do not use it.
          #
          # Bind to 127.0.0.1 — the in-pod Caddy sidecar (also in this pod's
          # network namespace) reverse-proxies external traffic to the same
          # 127.0.0.1:9119, so its connections arrive with TCP source 127.0.0.1
          # which IS in Hermes' built-in `_LOOPBACK_HOSTS` allow-list. That
          # avoids triggering the `--insecure` requirement (which Hermes
          # demands for non-loopback binds) and avoids the WS-upgrade rejection
          # that hits with `--host=0.0.0.0` (where uvicorn's `ws.client.host`
          # somehow ends up reporting the pod IP rather than 127.0.0.1).
          command: ["/opt/hermes/.venv/bin/hermes"]
          args:
            - "dashboard"
            - "--host=127.0.0.1"
            - "--port=9119"
            - "--no-open"
{% if _dashboard_tui %}
            - "--tui"
{% endif %}
          ports:
            - containerPort: 9119
              name: dashboard
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "{{ item.cpu_limit | default('2') }}"
              memory: "{{ item.memory_limit | default('2Gi') }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
          # Hermes binds to 127.0.0.1 only (we route external traffic via the
          # in-pod Caddy sidecar). kubelet tcpSocket probes hit the pod IP,
          # which Hermes does NOT listen on, so probes have to run inside the
          # container against loopback. Python is the only thing we can rely
          # on in the agent image (no curl/wget).
          livenessProbe:
            exec:
              command:
                - "/opt/hermes/.venv/bin/python3"
                - "-c"
                - "import socket;socket.create_connection(('127.0.0.1',9119),1).close()"
            initialDelaySeconds: 60
            periodSeconds: 30
            failureThreshold: 5
          readinessProbe:
            exec:
              command:
                - "/opt/hermes/.venv/bin/python3"
                - "-c"
                - "import socket;socket.create_connection(('127.0.0.1',9119),1).close()"
            initialDelaySeconds: 15
            periodSeconds: 10
        # Caddy + caddy-security sidecar — terminates auth as an HMAC-JWT
        # cookie session, then reverse-proxies to localhost:9119 (the bare
        # hermes dashboard). caddy-security validates the cookie ONLY on the
        # initial HTTP handshake — WebSocket upgrades and EventSource then
        # pass through transparently. This is the reason we switched from
        # oauth2-proxy v7 which would 403 every WS upgrade even with
        # --skip-auth-route + --cookie-csrf-per-request=false.
        # Image is greenpau/caddy-security packaged as `authcrunch/authcrunch`
        # (multi-arch). Listens cleartext on {{ hermes_agent_proxy_port }};
        # Traefik in front terminates TLS.
        - name: caddy
          image: "{{ hermes_caddy_image }}:{{ item.caddy_image_tag | default(hermes_caddy_image_tag) }}"
          imagePullPolicy: IfNotPresent
          command: ["caddy"]
          args: ["run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
          env:
            # JWT signing key used to sign the session cookie. Mounted from
            # the per-user Secret as a file; Caddyfile reads it via `{env.}`.
            - name: JWT_SIGNING_KEY
              valueFrom:
                secretKeyRef:
                  name: "hermes-caddy-{{ item.username }}"
                  key: signing_key
          ports:
            - containerPort: {{ hermes_agent_proxy_port }}
              name: auth
          resources:
            requests:
              cpu: "20m"
              memory: "32Mi"
            limits:
              cpu: "200m"
              memory: "128Mi"
          volumeMounts:
            - name: caddy-config
              mountPath: /etc/caddy
              readOnly: true
            # caddy-security writes to users.json (admin-bootstrap, password
            # rotation, MFA enrollment) — Secret-mounted /secrets would be
            # read-only and crash caddy on first start. Use a writable
            # emptyDir, seeded by the init-caddy-data initContainer below.
            - name: caddy-data
              mountPath: /secrets
          livenessProbe:
            tcpSocket:
              port: {{ hermes_agent_proxy_port }}
            initialDelaySeconds: 10
            periodSeconds: 30
          readinessProbe:
            tcpSocket:
              port: {{ hermes_agent_proxy_port }}
            initialDelaySeconds: 5
            periodSeconds: 10
        # Tail agent.log onto stdout so `kubectl logs -c log-tail <pod>` works
        # without execing into the pod. Inherits the pod-level securityContext
        # (runs as <uid>:<gid>) and reads /opt/data RO. Logs don't exist until
        # hermes first writes them, so wait for the file before exec'ing tail.
        - name: log-tail
          image: busybox:1.37
          command:
            - sh
            - -c
            - |
              until [ -f /opt/data/logs/agent.log ]; do sleep 2; done
              exec tail -n 0 -F /opt/data/logs/agent.log
          resources:
            requests:
              cpu: "10m"
              memory: "16Mi"
            limits:
              cpu: "100m"
              memory: "64Mi"
          volumeMounts:
            - name: data
              mountPath: /opt/data
              readOnly: true
      volumes:
        - name: data
          hostPath:
            path: "{{ hermes_data_base }}/{{ item.username }}"
            type: DirectoryOrCreate
        - name: seed-config
          configMap:
            name: "hermes-config-{{ item.username }}"
        - name: seed-secret
          secret:
            secretName: "hermes-env-{{ item.username }}"
        - name: caddy-config
          configMap:
            name: "hermes-caddy-{{ item.username }}"
            items:
              - key: Caddyfile
                path: Caddyfile
        - name: caddy-secret
          secret:
            secretName: "hermes-caddy-{{ item.username }}"
            items:
              - key: users.json
                path: users.json
        - name: caddy-data
          emptyDir: {}
