{# Per-user Hermes WebUI Deployment (ghcr.io/nesquena/hermes-webui).
   Runs in its own pod next to the agent pod. Both share the same NFS subdir
   hostPath as /opt/data — sessions/skills/configs are visible to both UIs.
   The WebUI still spawns its own `hermes` subprocesses for chat/tools (see
   upstream limitation #681); the agent pod's running process is independent.
#}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "hermes-webui-{{ item.username }}"
  namespace: "{{ hermes_namespace }}"
  labels:
    app: hermes
    hermes-component: webui
    hermes-user: "{{ item.username }}"
  annotations:
    # Keel auto-update: ghcr.io/nesquena/hermes-webui ships only `:latest`,
    # so `force` + `match-tag` redeploys whenever the digest behind :latest
    # changes upstream. Daily poll matches the rest of the cluster.
    keel.sh/policy: force
    keel.sh/match-tag: "true"
    keel.sh/pollSchedule: "@every 24h"
    keel.sh/trigger: poll
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: hermes
      hermes-component: webui
      hermes-user: "{{ item.username }}"
  template:
    metadata:
      labels:
        app: hermes
        hermes-component: webui
        hermes-user: "{{ item.username }}"
      annotations:
        # Default container for `kubectl logs`/`exec` — skips initContainer noise
        kubectl.kubernetes.io/default-container: hermes-webui
        # Auto-roll the pod when the seed config.yaml or .env changes
        # (e.g. flipping `hermes_debug` or rotating the litellm token).
        # Same shared ConfigMap/Secret as the agent pod — both initContainers
        # need to re-merge into /opt/data on update.
        checksum/config: "{{ lookup('template', 'hermes/hermes_config.yaml.j2') | hash('sha256') }}"
        checksum/env:    "{{ lookup('template', 'hermes/hermes_env.j2')         | hash('sha256') }}"
    spec:
      restartPolicy: Always
      nodeSelector:
        node-role: k3smaster
      # Pod-level securityContext targets the webui's image-internal user.
      # The image's docker_init.bash entrypoint MUST start as hermeswebuitoo
      # (UID 1025): it usermod's the hermeswebui user to WANTED_UID/WANTED_GID
      # and re-execs itself. After that switch the actual python server runs
      # as {{ item.uid }}/{{ item.gid }} (verified via /proc).
      # fsGroup={{ item.gid }} is added so the bootstrap shell can read /opt/data
      # before the switch; once switched, the server owns the dir directly.
      securityContext:
        runAsUser: 1025
        runAsGroup: 1025
        fsGroup: {{ item.gid }}
        runAsNonRoot: true
      initContainers:
        # Reset NFS subdir owner so the post-switch hermeswebui user (UID
        # {{ item.uid }}) can write. Idempotent — agent pod's fix-perms does the
        # same thing; whichever runs first wins, the other is a no-op.
        - name: fix-perms
          image: busybox:1.37
          command:
            - sh
            - -c
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data && chmod 0700 /opt/data"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
        # Strategic merge of ops-managed keys into /opt/data/config.yaml +
        # /opt/data/.env. Mirrors hermes-agent pod's merge-config initContainer
        # — needed because the webui spawns its own `hermes` subprocesses which
        # read the same config.yaml/.env. Race-safe because both pods derive
        # the same ops-managed values from the same ConfigMap/Secret. See
        # hermes_agent_deployment.yaml.j2 for the full EBUSY rationale.
        - name: merge-config
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes_image_tag) }}"
          command:
            - /opt/hermes/.venv/bin/python
            - -c
            - |
              import os, yaml
              UID, GID = {{ item.uid }}, {{ item.gid }}
              def deep_override(user, ops):
                  for k, v in ops.items():
                      if isinstance(v, dict) and isinstance(user.get(k), dict):
                          deep_override(user[k], v)
                      else:
                          user[k] = v
              ops = yaml.safe_load(open("/seed-config/config.yaml")) or {}
              try:
                  user = yaml.safe_load(open("/opt/data/config.yaml")) or {}
              except FileNotFoundError:
                  user = {}
              deep_override(user, ops)
              with open("/opt/data/config.yaml", "w") as f:
                  yaml.safe_dump(user, f, sort_keys=False)
              os.chown("/opt/data/config.yaml", UID, GID)
              os.chmod("/opt/data/config.yaml", 0o600)
              def parse_env(p):
                  out = {}
                  if not os.path.exists(p):
                      return out
                  for line in open(p):
                      s = line.strip()
                      if not s or s.startswith("#") or "=" not in s:
                          continue
                      k, v = s.split("=", 1)
                      out[k.strip()] = v
                  return out
              ops_env = parse_env("/seed-secret/.env")
              user_env = parse_env("/opt/data/.env")
              user_env.update(ops_env)
              with open("/opt/data/.env", "w") as f:
                  for k, v in user_env.items():
                      f.write(f"{k}={v}\n")
              os.chown("/opt/data/.env", UID, GID)
              os.chmod("/opt/data/.env", 0o600)
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: seed-config
              mountPath: /seed-config
              readOnly: true
            - name: seed-secret
              mountPath: /seed-secret
              readOnly: true
        # Provide the hermes-agent source tree to the webui. Upstream's
        # docker-compose.two-container.yml does the same via a named volume
        # (`hermes-agent-src`) populated from the agent image; we replicate it
        # with an emptyDir + initContainer copy so the webui pod is self-
        # contained (no cross-pod volume coupling). The webui's docker_init.bash
        # then runs `uv pip install <agent-src>[all]` against this dir.
        - name: copy-agent-src
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes_image_tag) }}"
          command:
            - sh
            - -c
            - "cp -a /opt/hermes/. /agent-src/ && chown -R {{ item.uid }}:{{ item.gid }} /agent-src"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: agent-src
              mountPath: /agent-src
      containers:
        - name: hermes-webui
          image: "{{ hermes_webui_image }}:{{ item.webui_image_tag | default(hermes_webui_image_tag) }}"
          imagePullPolicy: IfNotPresent
          env:
            - name: HERMES_WEBUI_HOST
              value: "0.0.0.0"
            - name: HERMES_WEBUI_PORT
              value: "{{ hermes_webui_port }}"
            - name: HERMES_HOME
              value: "/opt/data"
            - name: HERMES_WEBUI_AGENT_DIR
              value: "/opt/agent-src"
            - name: HERMES_WEBUI_STATE_DIR
              value: "/opt/data/.webui"
            # Auto-install hermes-agent runtime deps (dotenv, etc.) into the
            # webui venv on first start. Without this, "run_agent" features
            # break with ModuleNotFoundError; web UI itself still loads.
            - name: HERMES_WEBUI_AUTO_INSTALL
              value: "1"
            # Branding so the user knows whose dashboard they're on. Default
            # "Hermes (<username>)" — overridable via vault `webui_bot_name`.
            # Shown next to every assistant message in the chat.
            - name: HERMES_WEBUI_BOT_NAME
              value: "{{ item.webui_bot_name | default('Hermes (' ~ item.username ~ ')') }}"
            # Pin the default model in the model picker to our LiteLLM-backed
            # one. Empty would let the WebUI fall back to whatever provider
            # defaults exist (often an OpenAI model that's unavailable here, #646).
            - name: HERMES_WEBUI_DEFAULT_MODEL
              value: "{{ (item.litellm_model | default('')) or hermes_default_model }}"
            - name: WANTED_UID
              value: "{{ item.uid }}"
            - name: WANTED_GID
              value: "{{ item.gid }}"
            - name: HERMES_WEBUI_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: "hermes-env-{{ item.username }}"
                  key: WEBUI_PASSWORD
          ports:
            - containerPort: {{ hermes_webui_port }}
              name: webui
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "{{ item.webui_cpu_limit | default('1') }}"
              memory: "{{ item.webui_memory_limit | default('1Gi') }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: agent-src
              mountPath: /opt/agent-src
          livenessProbe:
            httpGet:
              path: /health
              port: {{ hermes_webui_port }}
            initialDelaySeconds: 90
            periodSeconds: 30
            failureThreshold: 5
          readinessProbe:
            httpGet:
              path: /health
              port: {{ hermes_webui_port }}
            initialDelaySeconds: 30
            periodSeconds: 10
      volumes:
        - name: data
          hostPath:
            path: "{{ hermes_data_base }}/{{ item.username }}"
            type: DirectoryOrCreate
        - name: agent-src
          emptyDir: {}
        - name: seed-config
          configMap:
            name: "hermes-config-{{ item.username }}"
        - name: seed-secret
          secret:
            secretName: "hermes-env-{{ item.username }}"
