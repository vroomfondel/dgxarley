{# Per-user Hermes WebUI Deployment (ghcr.io/nesquena/hermes-webui).
   Runs in its own pod next to the agent pod. Both share the same NFS subdir
   hostPath as /opt/data — sessions/skills/configs are visible to both UIs.
   The WebUI still spawns its own `hermes` subprocesses for chat/tools (see
   upstream limitation #681); the agent pod's running process is independent.

   Optional `hermes-email` sidecar (gated on item.email.enabled): runs
   `hermes gateway run` from the agent image to poll IMAP for incoming mail
   and dispatch it through Hermes' messaging pipeline. Outbound mail goes
   through tool-calls inside webui-spawned hermes subprocesses, which inherit
   the same /opt/data/.env — no extra wiring needed.
#}
{%- set _email = item.email | default({}) -%}
{%- set _email_enabled = _email.get('enabled', hermes_email_enabled_default) -%}
{#- /workspace gate: seadrive-mounted Seafile library vs NFS subdir hostPath.
    When enabled, the `files` volume becomes an emptyDir + a privileged
    seadrive FUSE sidecar bind-mounts the user's `hermes-workspace` lib onto
    it. Per-user override via item.seafile.workspace_enabled. -#}
{%- set _seafile = item.seafile | default({}) -%}
{%- set _seafile_workspace = (_seafile.get('workspace_enabled', hermes_seafile_workspace_enabled_default)) | bool -%}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "hermes-webui-{{ item.username }}"
  namespace: "{{ hermes_namespace }}"
  labels:
    app: hermes
    hermes-component: webui
    hermes-user: "{{ item.username }}"
  annotations:
    # Keel auto-update: ghcr.io/nesquena/hermes-webui ships only `:latest`,
    # so `force` + `match-tag` redeploys whenever the digest behind :latest
    # changes upstream. Daily poll matches the rest of the cluster.
    keel.sh/policy: force
    keel.sh/match-tag: "true"
    keel.sh/pollSchedule: "@every 24h"
    keel.sh/trigger: poll
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: hermes
      hermes-component: webui
      hermes-user: "{{ item.username }}"
  template:
    metadata:
      labels:
        app: hermes
        hermes-component: webui
        hermes-user: "{{ item.username }}"
      annotations:
        # Default container for `kubectl logs`/`exec` — skips initContainer noise
        kubectl.kubernetes.io/default-container: hermes-webui
        # Auto-roll the pod when the seed config.yaml or .env changes
        # (e.g. flipping `hermes_debug` or rotating the litellm token).
        # Same shared ConfigMap/Secret as the agent pod — both initContainers
        # need to re-merge into /opt/data on update.
        checksum/config:      "{{ lookup('template', 'hermes/hermes_config.yaml.j2') | hash('sha256') }}"
        checksum/env:         "{{ lookup('template', 'hermes/hermes_env.j2')         | hash('sha256') }}"
        # Hash the raw login secret so rotating basicauth_password (which is
        # only referenced by the Caddy users.json ConfigMap and the
        # WEBUI_PASSWORD Secret key — neither of which triggers a pod
        # rollover on its own) forces a fresh pod. Hash the cleartext, not
        # the bcrypt output: bcrypt re-salts on every render, which would
        # cause a spurious rollover on every playbook run.
        checksum/auth:        "{{ (item.basicauth_password | default(item.litellm_token)) | hash('sha256') }}"
{% if _email_enabled %}
        # Auto-roll when the gateway/platforms/email.py patch changes —
        # subPath ConfigMap mounts don't surface updates without a pod restart.
        checksum/email-patch: "{{ lookup('file', 'hermes_email_gateway_patched.py') | hash('sha256') }}"
{% endif %}
{% if _seafile_workspace %}
        # Auto-roll when the user's Seafile credentials change so the seadrive
        # sidecar picks them up; the hermes-seafile-<user> Secret is loaded
        # via envFrom and only re-read on container start.
        checksum/seafile:     "{{ (hermes_seafile_server_url ~ '|' ~ (item.email.address | default('?')) ~ '|' ~ (item.seafile.web_password | default('none'))) | hash('sha256') }}"
{% endif %}
    spec:
      restartPolicy: Always
      # Cross-container gateway-liveness fix (#1879 in nesquena/hermes-webui):
      # WebUI's `api/agent_health.py` first calls `os.kill(pid, 0)` on the PID
      # written to `gateway_state.json` by the hermes-email sidecar. Without a
      # shared PID namespace that always fails (PID lives in the other
      # container) and the dashboard falls back to a 120 s freshness check on
      # the state file — which v2026.5.x agent only updates on platform
      # lifecycle changes, so it goes stale within minutes and the UI shows
      # "Gateway not configured". Sharing the PID namespace makes the PID
      # check succeed directly. Side effect: pause-container becomes PID 1.
      shareProcessNamespace: true
      nodeSelector:
        node-role: k3smaster
      # Pod-level securityContext: the webui image's hermeswebui_init.bash
      # entrypoint REQUIRES starting as root (UID 0). It then `usermod`s the
      # baked-in `hermeswebui` user to WANTED_UID/WANTED_GID, prepares root-
      # owned paths (/app, $UV_CACHE_DIR, /opt/data), and `exec su`s itself
      # to `hermeswebui`. The python server runs as {{ item.uid }}/{{ item.gid }}.
      #
      # Earlier image versions (pre-2026-05-15) shipped sudo + a separate
      # hermeswebuitoo user (UID 1025) that did the bootstrap and dropped
      # to hermeswebui (UID 1024). The new production image dropped sudo
      # entirely; the bootstrap now ONLY runs when whoami == root, otherwise
      # the script aborts with `current UID 1025 ≠ wanted ${WANTED_UID}`.
      # See script: `if [ "A${whoami}" == "Aroot" ]; then ... usermod ...
      # exec su -s /bin/bash -c "exec ..." hermeswebui`.
      #
      # fsGroup={{ item.gid }} so the post-switch hermeswebui user can read
      # the NFS-mounted /opt/data; the bootstrap as root doesn't need it.
      securityContext:
        runAsUser: 0
        runAsGroup: 0
        fsGroup: {{ item.gid }}
        runAsNonRoot: false
      initContainers:
        # Reset NFS subdir owner so the post-switch hermeswebui user (UID
        # {{ item.uid }}) can write. Idempotent — agent pod's fix-perms does the
        # same thing; whichever runs first wins, the other is a no-op.
        - name: fix-perms
          image: busybox:latest
          command:
            - sh
            - -c
{% if _seafile_workspace %}
            # /workspace is FUSE-managed by the seadrive sidecar — POSIX
            # owner is set by seadrive's mount options. Only fix /opt/data.
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data && chmod 0700 /opt/data"
{% else %}
            - "chown {{ item.uid }}:{{ item.gid }} /opt/data /workspace && chmod 0700 /opt/data /workspace"
{% endif %}
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
{% if not _seafile_workspace %}
            - name: files
              mountPath: /workspace
{% endif %}
        # Strategic merge of ops-managed keys into /opt/data/config.yaml +
        # /opt/data/.env. Mirrors hermes-agent pod's merge-config initContainer
        # — needed because the webui spawns its own `hermes` subprocesses which
        # read the same config.yaml/.env. Race-safe because both pods derive
        # the same ops-managed values from the same ConfigMap/Secret. See
        # hermes_agent_deployment.yaml.j2 for the full EBUSY rationale.
        - name: merge-config
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes_image_tag) }}"
          command:
            - /opt/hermes/.venv/bin/python
            - -c
            - |
              import os, yaml
              UID, GID = {{ item.uid }}, {{ item.gid }}
              def deep_override(user, ops):
                  for k, v in ops.items():
                      if isinstance(v, dict) and isinstance(user.get(k), dict):
                          deep_override(user[k], v)
                      else:
                          user[k] = v
              ops = yaml.safe_load(open("/seed-config/config.yaml")) or {}
              try:
                  user = yaml.safe_load(open("/opt/data/config.yaml")) or {}
              except FileNotFoundError:
                  user = {}
              deep_override(user, ops)
              with open("/opt/data/config.yaml", "w") as f:
                  yaml.safe_dump(user, f, sort_keys=False)
              os.chown("/opt/data/config.yaml", UID, GID)
              os.chmod("/opt/data/config.yaml", 0o600)
              def parse_env(p):
                  out = {}
                  if not os.path.exists(p):
                      return out
                  for line in open(p):
                      s = line.strip()
                      if not s or s.startswith("#") or "=" not in s:
                          continue
                      k, v = s.split("=", 1)
                      out[k.strip()] = v
                  return out
              ops_env = parse_env("/seed-secret/.env")
              user_env = parse_env("/opt/data/.env")
              user_env.update(ops_env)
              with open("/opt/data/.env", "w") as f:
                  for k, v in user_env.items():
                      f.write(f"{k}={v}\n")
              os.chown("/opt/data/.env", UID, GID)
              os.chmod("/opt/data/.env", 0o600)
              # Merge STATE_DIR/settings.json with the WebUI preferences
              # defined in `webui_settings` on this user. Mirrors the
              # config.yaml/.env merge above — ops-managed keys WIN, all
              # other keys the user has set via the Preferences panel
              # (POST /api/settings) are preserved. The nine ops-relevant
              # toggles live in api/config.py:_SETTINGS_DEFAULTS upstream
              # (sidebar_density, show_cli_sessions, simplified_tool_calling,
              # busy_input_mode, …); none has an env/config override.
{% set _webui_settings = item.webui_settings | default({}) %}
{% if _webui_settings %}
              import base64, json
              state_dir = "/opt/data/.webui"
              settings_path = os.path.join(state_dir, "settings.json")
              os.makedirs(state_dir, exist_ok=True)
              os.chown(state_dir, UID, GID)
              os.chmod(state_dir, 0o700)
              # base64 round-trip — the rendered JSON contains lowercase
              # `true`/`false`/`null` which are not valid Python literals;
              # parsing through json.loads avoids any quoting/escaping
              # corner cases (single quotes in values etc.).
              ops_settings = json.loads(base64.b64decode("{{ _webui_settings | to_json | b64encode }}"))
              try:
                  user_settings = json.load(open(settings_path))
                  if not isinstance(user_settings, dict):
                      user_settings = {}
              except (FileNotFoundError, json.JSONDecodeError):
                  user_settings = {}
              user_settings.update(ops_settings)  # ops keys win
              with open(settings_path, "w") as f:
                  json.dump(user_settings, f, indent=2, sort_keys=True)
              os.chown(settings_path, UID, GID)
              os.chmod(settings_path, 0o600)
{% endif %}
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: seed-config
              mountPath: /seed-config
              readOnly: true
            - name: seed-secret
              mountPath: /seed-secret
              readOnly: true
        # Provide the hermes-agent source tree to the webui. Upstream's
        # docker-compose.two-container.yml does the same via a named volume
        # (`hermes-agent-src`) populated from the agent image; we replicate it
        # with an emptyDir + initContainer copy so the webui pod is self-
        # contained (no cross-pod volume coupling). The webui's docker_init.bash
        # then runs `uv pip install <agent-src>[all]` against this dir.
        - name: copy-agent-src
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes_image_tag) }}"
          command:
            - sh
            - -c
            # Also write a VERSION file with the image tag — upstream's
            # _detect_agent_version() (api/updates.py:145) looks for
            # <agent_dir>/VERSION first, falls back to `git describe` in the
            # source tree. The Docker image ships neither, so without this
            # the System page shows "Agent: not detected" even though the
            # agent code is fully present and functional. Use the resolved
            # image tag as the version label.
            - "cp -a /opt/hermes/. /agent-src/ && printf '%s\\n' '{{ item.image_tag | default(hermes_image_tag) }}' > /agent-src/VERSION && chown -R {{ item.uid }}:{{ item.gid }} /agent-src"
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: agent-src
              mountPath: /agent-src
      containers:
{% if _seafile_workspace %}
        # ===== seadrive FUSE sidecar =========================================
        # Mounts the user's `hermes-workspace` Seafile library as /workspace,
        # shared with the other containers in this pod via a Bidirectional
        # mountPropagation on an emptyDir. Requires privileged + /dev/fuse.
        #
        # Sequence:
        #   1. Render seadrive.conf from the hermes-seafile-<user> Secret
        #   2. Launch seadrive in the background, mounting all libs at
        #      /seadrive — `hermes-workspace` appears at /seadrive/hermes-workspace
        #   3. Wait for that subdir to materialise (FUSE async cache)
        #   4. bind-mount it onto /workspace (the shared emptyDir mount point);
        #      via Bidirectional propagation this becomes visible to webui +
        #      hermes-email containers as their /workspace contents.
        #   5. wait on the seadrive process; preStop unmounts cleanly.
        - name: seadrive
          image: "{{ hermes_seadrive_image }}:{{ hermes_seadrive_image_tag }}"
          imagePullPolicy: IfNotPresent
          securityContext:
            privileged: true
            runAsUser: 0
            runAsNonRoot: false
          envFrom:
            - secretRef:
                name: "hermes-seafile-{{ item.username }}"
          env:
            - name: WANTED_UID
              value: "{{ item.uid }}"
            - name: WANTED_GID
              value: "{{ item.gid }}"
            - name: SEAFILE_LIBRARY_NAME
              value: "{{ hermes_seafile_library_name }}"
          command:
            - /bin/bash
            - -c
            - |
              set -euo pipefail
              # FUSE needs /etc/fuse.conf with user_allow_other so containers
              # running as a different UID can read /workspace contents.
              mkdir -p /etc /var/cache/seadrive /seadrive
              grep -q '^user_allow_other' /etc/fuse.conf 2>/dev/null \
                || echo 'user_allow_other' >> /etc/fuse.conf

              cat > /tmp/seadrive.conf <<EOF
              [account]
              server = ${SEAFILE_SERVER}
              username = ${SEAFILE_USER}
              token = ${SEAFILE_TOKEN}
              is_pro = false

              [general]
              client_name = hermes-${HOSTNAME}
              EOF
              chmod 0600 /tmp/seadrive.conf

              # Background seadrive; -f keeps it foreground but we want it
              # parallel with the bind-mount step.
              seadrive \
                -c /tmp/seadrive.conf \
                -d /var/cache/seadrive \
                -l /var/log/seadrive.log \
                -o allow_other,uid=${WANTED_UID},gid=${WANTED_GID},umask=0077 \
                /seadrive &
              SEADRIVE_PID=$!

              # Wait for the library to appear (FUSE caches lazily; ~3–10s).
              for i in $(seq 1 60); do
                  if [ -d "/seadrive/${SEAFILE_LIBRARY_NAME}" ]; then
                      break
                  fi
                  sleep 1
              done
              if [ ! -d "/seadrive/${SEAFILE_LIBRARY_NAME}" ]; then
                  echo "seadrive: library '${SEAFILE_LIBRARY_NAME}' did not appear within 60s — check Seafile credentials/server reachability" >&2
                  cat /var/log/seadrive.log >&2 || true
                  kill ${SEADRIVE_PID} 2>/dev/null || true
                  exit 1
              fi

              # Propagate the lib content onto the shared emptyDir mount.
              mount --bind "/seadrive/${SEAFILE_LIBRARY_NAME}" /workspace
              echo "seadrive: ${SEAFILE_LIBRARY_NAME} mounted at /workspace (pid=${SEADRIVE_PID})"

              # Forward signals to seadrive so K8s graceful shutdown works.
              trap 'umount /workspace 2>/dev/null || true; fusermount -u /seadrive 2>/dev/null || true; kill -TERM ${SEADRIVE_PID} 2>/dev/null || true' TERM INT
              wait ${SEADRIVE_PID}
          volumeMounts:
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: Bidirectional
          lifecycle:
            preStop:
              exec:
                command:
                  - /bin/sh
                  - -c
                  - "umount /workspace 2>/dev/null || true; fusermount -u /seadrive 2>/dev/null || true"
          resources:
            requests:
              cpu: "20m"
              memory: "64Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
{% endif %}
        - name: hermes-webui
          image: "{{ hermes_webui_image }}:{{ item.webui_image_tag | default(hermes_webui_image_tag) }}"
          imagePullPolicy: IfNotPresent
          env:
            - name: HERMES_WEBUI_HOST
              value: "0.0.0.0"
            - name: HERMES_WEBUI_PORT
              value: "{{ hermes_webui_port }}"
            - name: HERMES_HOME
              value: "/opt/data"
            - name: HERMES_WEBUI_AGENT_DIR
              value: "/opt/agent-src"
            - name: HERMES_WEBUI_STATE_DIR
              value: "/opt/data/.webui"
            # Auto-install hermes-agent runtime deps (dotenv, etc.) into the
            # webui venv on first start. Without this, "run_agent" features
            # break with ModuleNotFoundError; web UI itself still loads.
            - name: HERMES_WEBUI_AUTO_INSTALL
              value: "1"
            # Branding so the user knows whose dashboard they're on. Default
            # "Hermes (<username>)" — overridable via vault `webui_bot_name`.
            # Shown next to every assistant message in the chat.
            - name: HERMES_WEBUI_BOT_NAME
              value: "{{ item.webui_bot_name | default('Hermes (' ~ item.username ~ ')') }}"
            # Pin the default model in the model picker to our LiteLLM-backed
            # one. Empty would let the WebUI fall back to whatever provider
            # defaults exist (often an OpenAI model that's unavailable here, #646).
            - name: HERMES_WEBUI_DEFAULT_MODEL
              value: "{{ (item.litellm_model | default('')) or hermes_default_model }}"
            - name: WANTED_UID
              value: "{{ item.uid }}"
            - name: WANTED_GID
              value: "{{ item.gid }}"
            - name: HERMES_WEBUI_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: "hermes-env-{{ item.username }}"
                  key: WEBUI_PASSWORD
          ports:
            - containerPort: {{ hermes_webui_port }}
              name: webui
          resources:
            requests:
              cpu: "50m"
              memory: "128Mi"
            limits:
              cpu: "{{ item.webui_cpu_limit | default('1') }}"
              memory: "{{ item.webui_memory_limit | default('1Gi') }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
            - name: agent-src
              mountPath: /opt/agent-src
{% if _seafile_workspace %}
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: HostToContainer
{% else %}
            - name: files
              mountPath: /workspace
{% endif %}
          livenessProbe:
            httpGet:
              path: /health
              port: {{ hermes_webui_port }}
            initialDelaySeconds: 90
            periodSeconds: 30
            failureThreshold: 5
          readinessProbe:
            httpGet:
              path: /health
              port: {{ hermes_webui_port }}
            initialDelaySeconds: 30
            periodSeconds: 10
{% if _email_enabled %}
        # Email gateway sidecar — polls IMAP and dispatches via SMTP using the
        # EMAIL_* vars from /opt/data/.env (merged by the merge-config init).
        # Uses the agent image because the `hermes` CLI lives there. The image's
        # /init (s6-overlay since v2026.5.28) usermod's the baked-in `hermes`
        # user to HERMES_UID/GID via cont-init, then main-wrapper.sh
        # `s6-setuidgid hermes`-drops before exec'ing `hermes gateway run`
        # (pre-s6 this was the entrypoint + gosu). No HTTP port — the gateway
        # is daemon-only; rely on K8s restart-on-crash for liveness.
        # Shares /opt/data with the webui container so both see the same
        # sessions/skills/.env. Outbound mail from webui-spawned hermes
        # subprocesses also works via the same .env, no extra wiring needed.
        - name: hermes-email
          image: "nousresearch/hermes-agent:{{ item.image_tag | default(hermes_image_tag) }}"
          imagePullPolicy: Always
          args:
            - "gateway"
            - "run"
          securityContext:
            runAsUser: 0
            runAsGroup: 0
            runAsNonRoot: false
          env:
            - name: HERMES_UID
              value: "{{ item.uid }}"
            - name: HERMES_GID
              value: "{{ item.gid }}"
            # Pin HERMES_HOME into the shared /opt/data hostPath so the
            # gateway writes its gateway.pid / gateway_state.json / state.db
            # where the webui pod can see them. Without this the sidecar
            # falls back to a container-local default (~/.hermes) and the
            # webui's /api/gateway/status always reports "Gateway not
            # configured" — and gateway-originated sessions (Email etc.)
            # never appear in the WebUI session list (see #1879).
            - name: HERMES_HOME
              value: "/opt/data"
          resources:
            requests:
              cpu: "20m"
              memory: "128Mi"
            limits:
              cpu: "{{ item.email.cpu_limit | default('500m') }}"
              memory: "{{ item.email.memory_limit | default('512Mi') }}"
          volumeMounts:
            - name: data
              mountPath: /opt/data
{% if _seafile_workspace %}
            - name: workspace-fuse
              mountPath: /workspace
              mountPropagation: HostToContainer
{% else %}
            - name: files
              mountPath: /workspace
{% endif %}
            # dgxarley local patch — overlays the upstream gateway/platforms/
            # email.py with the version under
            # roles/k8s_dgx/files/hermes_email_gateway_patched.py.  Adds
            # Working/Done folder lifecycle, IMAP APPEND to Sent, and the
            # EMAIL_PROCESS_EXISTING knob (see file's PATCH header).
            # subPath gives us a single-file bind mount — the rest of
            # /opt/hermes (venv, ui-tui, hooks, etc.) stays untouched from
            # the image. Pin: file content must match the upstream source
            # of hermes_image_tag; re-sync on image bump.
            - name: hermes-email-patch
              mountPath: /opt/hermes/gateway/platforms/email.py
              subPath: email.py
              readOnly: true
{% endif %}
      volumes:
        - name: data
          hostPath:
            path: "{{ hermes_data_base }}/{{ item.username }}"
            type: DirectoryOrCreate
{% if _seafile_workspace %}
        # /workspace is FUSE-managed by the seadrive sidecar; the emptyDir
        # just provides a shared mountpoint across containers in the pod.
        - name: workspace-fuse
          emptyDir: {}
{% else %}
        # User-managed input/output shelf, mounted at /workspace. Same per-user
        # NFS subdir isolation as the data volume.
        - name: files
          hostPath:
            path: "{{ hermes_files_base }}/{{ item.username }}"
            type: DirectoryOrCreate
{% endif %}
        - name: agent-src
          emptyDir: {}
        - name: seed-config
          configMap:
            name: "hermes-config-{{ item.username }}"
        - name: seed-secret
          secret:
            secretName: "hermes-env-{{ item.username }}"
{% if _email_enabled %}
        - name: hermes-email-patch
          configMap:
            name: hermes-email-patch
            items:
              - key: email.py
                path: email.py
{% endif %}
