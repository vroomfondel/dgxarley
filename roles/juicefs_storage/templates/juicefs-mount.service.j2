# Managed by Ansible (juicefs_storage) — do not edit.
[Unit]
Description=JuiceFS mount {{ juicefs_mount_path }} ({{ juicefs_fs_name }})
After=network-online.target
Wants=network-online.target
{% if inventory_hostname == juicefs_primary_node %}
# On the storage node the backend is local — order after it.
After={{ juicefs_valkey_apt_package }}.service rustfs.service
{% endif %}

[Service]
Type=simple
EnvironmentFile=/etc/juicefs/{{ juicefs_fs_name }}.env
# Clear any stale FUSE mount left by an unclean exit before remounting.
ExecStartPre=-/bin/umount -l {{ juicefs_mount_path }}
{# --metrics: expose the client's Prometheus endpoint on the k3s-VLAN IP (the
   default bind is 127.0.0.1:9567) so the in-cluster Prometheus can scrape the
   bare-metal mounts. iptables gates the port to k3snodes (common role). The IP
   is static (netplan) and the unit self-heals (Restart=always) on a bind race. #}
ExecStart=/usr/local/bin/juicefs mount --cache-dir {{ juicefs_cache_dir }} --cache-size {{ juicefs_cache_size_mib }} --backup-meta {{ juicefs_backup_meta_interval }}{% if juicefs_writeback %} --writeback{% endif %}{% if juicefs_metrics_enabled | default(false) | bool %} --metrics {{ k3s_node_ip }}:{{ juicefs_metrics_port }}{% endif %}{% if juicefs_allow_other %} -o allow_other{% endif %} redis://{{ juicefs_storage_address }}:6379/{{ juicefs_meta_db }} {{ juicefs_mount_path }}
ExecStop=/bin/umount {{ juicefs_mount_path }}
Restart=always
RestartSec=10s
# Never give up restarting (storage node may come back later).
StartLimitIntervalSec=0

[Install]
WantedBy=multi-user.target
