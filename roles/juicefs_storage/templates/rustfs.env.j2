# Managed by Ansible (juicefs_storage) — do not edit. Contains secrets.
RUSTFS_ACCESS_KEY={{ juicefs_rustfs_access_key }}
RUSTFS_SECRET_KEY={{ juicefs_rustfs_secret_key }}
{% if juicefs_rustfs_distributed | bool %}
{# Distributed erasure-coded cluster: RUSTFS_VOLUMES lists EVERY volume across
   ALL nodes and MUST be byte-identical on every node. Built from the structured
   juicefs_rustfs_members (node -> disks[]); each node is reached on its QSFP IP
   (200GbE mesh), falling back to its k3s VLAN IP. Object dir on each disk =
   <mount>/rustfs. Order follows the list order (positional erasure membership). #}
{% set vols = [] %}
{% for e in juicefs_rustfs_members %}
{%   set addr = hostvars[e.node].qsfp_ip | default(hostvars[e.node].k3s_node_ip) %}
{%   for d in e.disks %}
{%     set _ = vols.append('http://' ~ addr ~ ':' ~ juicefs_rustfs_s3_port ~ d.path ~ '/rustfs') %}
{%   endfor %}
{% endfor %}
RUSTFS_VOLUMES={{ vols | join(' ') }}
{# Erasure config: set size = drives per set; EC:M = parity blocks (raid0/5/6). #}
RUSTFS_ERASURE_SET_DRIVE_COUNT={{ juicefs_rustfs_set_drive_count }}
RUSTFS_STORAGE_CLASS_STANDARD=EC:{{ juicefs_rustfs_parity }}
{% else %}
RUSTFS_VOLUMES={{ juicefs_rustfs_data_dir }}
{% endif %}
RUSTFS_ADDRESS=0.0.0.0:{{ juicefs_rustfs_s3_port }}
RUSTFS_CONSOLE_ENABLE={{ juicefs_rustfs_console_enable | bool | lower }}
RUSTFS_CONSOLE_ADDRESS=0.0.0.0:{{ juicefs_rustfs_console_port }}
